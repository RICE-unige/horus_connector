# Copy to .env and edit for your machine.

# role: robot, machine, or cloud
HORUS_ROLE=robot

# Pairing room for WebRTC signaling. Use one room per robot-machine pair.
HORUS_ROOM=robot1

# topology:
#   hub    robot(s) and machine(s) connect through one cloud relay/router
#   direct robot connects straight to machine over VPN/Tailscale/LAN
HORUS_TOPOLOGY=hub

# Shared cloud relay/router endpoint for hub mode.
HORUS_CLOUD_IP=

# Operator/local machine endpoint for direct mode, or for WebRTC in hub mode
# when the robot can reach the machine directly by VPN/Tailscale/public IP.
HORUS_MACHINE_IP=

# Optional override for the WebRTC signaling receiver address.
# If empty, robot uses HORUS_MACHINE_IP when set, otherwise HORUS_CLOUD_IP.
HORUS_WEBRTC_SIGNAL_IP=

HORUS_SSH_ALIAS=googlecloud
REMOTE_DIR=~/horus_connector

# ROS.
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=0
ROS_CMD_TOPIC=/cmd_vel

# Optional namespace for multi-robot deployments, for example /robot1.
ZENOH_NAMESPACE=

# Zenoh.
ZENOH_PORT=7447
ZENOH_VERSION=1.9.0
ZENOH_CONFIG=config/zenoh_split.json5

# WebRTC.
WEBRTC_MEDIA_MODE=h264
WEBRTC_SIGNAL_PORT=8765
WEBRTC_DURATION=86400
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
WEBRTC_MAX_BUFFER_BYTES=2000000
WEBRTC_VIDEO_WIDTH=1280
WEBRTC_VIDEO_HEIGHT=720
WEBRTC_VIDEO_FPS=30
WEBRTC_VIDEO_SINK=fakesink
WEBRTC_GST_VIDEO_SOURCE=
VIDEO_BITRATE_KBIT=6000
WEBRTC_ENCODER_PREFERENCE=x264
WEBRTC_DECODER_PREFERENCE=software

# In hub mode, the cloud relays WebRTC signaling only. It does not encode or decode media.
HORUS_CLOUD_RUN_SIGNALING=1

# Synthetic camera stream used for validation/load testing.
CAMERA_FPS_SCALE=1.0
CAMERA_QUALITY_SCALE=1.0

# Machine/cloud-to-robot test control stream. Keep 0 unless deliberately testing.
CMD_RATE=0
CMD_LINEAR_X=0.0
CMD_ANGULAR_Z=0.0
