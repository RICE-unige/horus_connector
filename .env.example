# Copy to .env and edit for your machine.

# role: robot, machine, or cloud
HORUS_ROLE=robot

# Pairing room for WebRTC signaling. Use one room per robot-machine pair.
HORUS_ROOM=robot-a

# topology:
#   hub    robot(s) and machine(s) connect through one cloud relay/router
#   direct robot connects straight to machine over VPN/Tailscale/LAN
HORUS_TOPOLOGY=hub

# Shared cloud relay/router endpoint for hub mode.
HORUS_CLOUD_IP=

# Operator/local machine endpoint for direct mode.
HORUS_MACHINE_IP=

# Optional override for the WebRTC signaling receiver address.
# If empty, direct mode uses HORUS_MACHINE_IP and hub mode uses HORUS_CLOUD_IP.
HORUS_WEBRTC_SIGNAL_IP=

HORUS_SSH_ALIAS=cloud-host
REMOTE_DIR=~/horus_connector

# ROS. Match ROS_DISTRO to the ROS 2 distro installed on this machine
# (for example humble or jazzy).
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=0
# Optional. Set this when ROS 2 was installed/built outside /opt/ros/<distro>.
# Examples: /opt/ros/humble/setup.bash or ~/ros2_humble/install/setup.bash
ROS_SETUP_PATH=
ROS_LOCALHOST_ONLY=1
ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST
ROS_CMD_TOPIC=/cmd_vel

# Optional namespace for multi-robot deployments, for example /robot_a.
ZENOH_NAMESPACE=

# Zenoh.
ZENOH_PORT=7447
ZENOH_VERSION=1.9.0
ZENOH_CONFIG=auto
# auto uses TCP unless QUIC is explicitly enabled after TLS cert/key setup.
ZENOH_TRANSPORT=auto
ZENOH_AUTO_ENABLE_QUIC=0
# QUIC endpoint options used when QUIC is active on Zenoh 1.9+.
ZENOH_QUIC_PARAMS=multistream=1;mixed_rel=auto
# Optional Zenoh TLS paths. Normal users should use:
#   cloud/listener: ./horus quic setup-server
#   robot/machine: ./horus quic install-cert <hub-cert.pem>
ZENOH_TLS_DIR=
ZENOH_TLS_ROOT_CA=
ZENOH_TLS_LISTEN_KEY=
ZENOH_TLS_LISTEN_CERT=
ZENOH_TLS_VERIFY_NAME=0
HORUS_ZENOH_ENABLED=1

# WebRTC.
# h264 is the supported hub/direct media path. jpeg is a legacy direct-mode fallback only.
WEBRTC_MEDIA_MODE=h264
HORUS_ALLOW_LEGACY_JPEG=0
WEBRTC_SIGNAL_PORT=8765
WEBRTC_DURATION=86400
# Comma-separated ICE servers. Add TURN for NAT-heavy hub deployments, for example:
# WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302,turn://user:pass@cloud.example.com:3478
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
# all prefers direct WebRTC and uses TURN only as fallback. relay forces TURN for validation/debugging.
WEBRTC_ICE_TRANSPORT_POLICY=all
HORUS_WEBRTC_DEBUG_ICE=0
HORUS_CLOUD_RUN_TURN=0
TURN_PORT=3478
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535
TURN_REALM=horus
TURN_USER=horus
TURN_PASSWORD=change-me
TURN_PRIVATE_IP=
WEBRTC_MAX_BUFFER_BYTES=2000000
WEBRTC_VIDEO_WIDTH=1280
WEBRTC_VIDEO_HEIGHT=720
WEBRTC_VIDEO_FPS=30
WEBRTC_VIDEO_SOURCE=ros2
WEBRTC_VIDEO_OUTPUT=ros2
WEBRTC_VIDEO_SINK=fakesink
WEBRTC_GST_VIDEO_SOURCE=
WEBRTC_ROS_IMAGE_INPUT_TOPIC=/camera/image_raw
WEBRTC_ROS_IMAGE_OUTPUT_TOPIC=/camera/webrtc/image_raw
WEBRTC_ROS_IMAGE_OUTPUT_ENCODING=rgb8
WEBRTC_ROS_IMAGE_FRAME_ID=webrtc_camera
WEBRTC_ROS_IMAGE_QOS=auto
VIDEO_BITRATE_KBIT=6000
WEBRTC_ADAPTIVE_BITRATE=1
WEBRTC_MIN_BITRATE_KBIT=1000
WEBRTC_MAX_BITRATE_KBIT=6000
WEBRTC_BITRATE_STEP_KBIT=500
WEBRTC_BITRATE_CHECK_SEC=2.0
WEBRTC_H264_KEY_INT_MAX=10
# WebRTC is video-only by default. Velocity commands stay on ROS 2 and cross the bridge through Zenoh.
WEBRTC_CONTROL_ENABLED=0
# Legacy alias kept for older local env files.
WEBRTC_ENABLE_CONTROL=0
# Required when WEBRTC_CONTROL_ENABLED=1. Share this token only with authorized operators.
HORUS_WEBRTC_CONTROL_TOKEN=
# Only set this to 1 for trusted lab tests where token-based control authorization is intentionally disabled.
WEBRTC_ALLOW_UNAUTHENTICATED_CONTROL=0
WEBRTC_CMD_MAX_LINEAR_MPS=0.5
WEBRTC_CMD_MAX_ANGULAR_RPS=1.0
WEBRTC_CMD_WATCHDOG_TIMEOUT=0.3
WEBRTC_CMD_RATE_LIMIT_HZ=100.0
# stable prefers the path proven by the end-to-end WebRTC/ROS test:
# x264/libav on normal Linux/NUC/WSL, Jetson hardware where required.
# Set hardware to opt into Jetson NVIDIA V4L2, Intel/DRM VAAPI, or NVIDIA NVENC first.
WEBRTC_ENCODER_PREFERENCE=stable
WEBRTC_DECODER_PREFERENCE=stable
# Intel systems install the free VA driver by default. Set non-free only if your hardware needs it.
HORUS_INTEL_MEDIA_DRIVER=free

# In hub mode, the cloud relays WebRTC signaling only. It does not encode or decode media.
HORUS_CLOUD_RUN_SIGNALING=1
# Set this on robot, machine, and cloud to authenticate hub signaling rooms.
HORUS_WEBRTC_RELAY_TOKEN=
# Only set this to 1 on trusted test networks when running a public signaling relay without a token.
HORUS_WEBRTC_RELAY_ALLOW_UNAUTHENTICATED=0

# Synthetic camera stream used for validation/load testing.
FAKE_DATA_ROBOT_ID=robot-a
FAKE_ROS_IMAGE_TOPIC=/camera/image_raw
FAKE_ROS_ODOM_TOPIC=/odom
FAKE_ROS_SCAN_TOPIC=/scan
FAKE_ROS_JOINT_TOPIC=/joint_states
FAKE_ROS_POINTS_TOPIC=/points
FAKE_ROS_IMAGE_QOS=default
FAKE_CAMERA_WIDTH=1280
FAKE_CAMERA_HEIGHT=720
FAKE_CAMERA_FPS=30
FAKE_FRAME_CACHE=30
FAKE_STATE_RATE=20
FAKE_POINTS_RATE=1
FAKE_POINT_COUNT=512
FAKE_COLOR_SEED=17
CAMERA_FPS_SCALE=1.0
CAMERA_QUALITY_SCALE=1.0

# Runtime observability.
HORUS_LOG_KEEP=10
HORUS_METRICS_PORT=

# Machine/cloud-to-robot test control stream. Keep 0 unless deliberately testing.
CMD_RATE=0
CMD_LINEAR_X=0.0
CMD_ANGULAR_Z=0.0
