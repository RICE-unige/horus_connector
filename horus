        --ros-image-topic "${output_topic}" \
        --ros-image-encoding "${WEBRTC_ROS_IMAGE_OUTPUT_ENCODING:-rgb8}" \
        --ros-image-frame-id "${frame_id}" \
        --ros-image-qos "${qos}" \
        --cmd-rate "${cmd_rate}" \
        --cmd-linear-x "${CMD_LINEAR_X:-0.0}" \
        --cmd-angular-z "${CMD_ANGULAR_Z:-0.0}" \
        "${optional_args[@]}" \
        --duration "${WEBRTC_DURATION:-86400}"
    fi
  done
}

launch_webrtc_robot() {
  local py
  local target
  local optional_args=()
  local control_enabled
  ensure_webrtc_media_supported
  py="$(python_bin)"
  target="$(webrtc_signal_target)"
  control_enabled="$(webrtc_control_enabled)"
  source_ros_required
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    build_ice_args optional_args
    start_bg webrtc "${py}" "${ROOT}/scripts/webrtc_camera_sender.py" \
      --signaling-url "ws://${target}:${WEBRTC_SIGNAL_PORT:-8765}" \
      --duration "${WEBRTC_DURATION:-86400}" \
      --camera-fps-scale "${CAMERA_FPS_SCALE:-1.0}" \
      --quality-scale "${CAMERA_QUALITY_SCALE:-1.0}" \
      --max-buffer-bytes "${WEBRTC_MAX_BUFFER_BYTES:-2000000}" \
      --enable-control "${control_enabled}" \
      --ros-cmd-topic "${ROS_CMD_TOPIC:-/cmd_vel}" \
      --control-token "${HORUS_WEBRTC_CONTROL_TOKEN:-}" \
      --allow-unauthenticated-control "${WEBRTC_ALLOW_UNAUTHENTICATED_CONTROL:-0}" \
      --cmd-max-linear-mps "${WEBRTC_CMD_MAX_LINEAR_MPS:-0.5}" \
      --cmd-max-angular-rps "${WEBRTC_CMD_MAX_ANGULAR_RPS:-1.0}" \
      "${optional_args[@]}" \
      --json "${RUN_DIR}/webrtc_robot_summary.json"
  else
    launch_webrtc_robot_h264_streams "${py}" "${target}" "${control_enabled}"
  fi
}

launch_webrtc_receiver() {
  local role="$1"
  local py
  local target
  local optional_args=()
  local cmd_rate
  ensure_webrtc_media_supported
  py="$(python_bin)"
  source_ros_required
  target="$(webrtc_signal_target)"
  cmd_rate="${CMD_RATE:-0}"
  if [[ "$(webrtc_control_enabled)" != "1" ]]; then
    cmd_rate="0"
  fi
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    build_ice_args optional_args
    start_bg webrtc "${py}" "${ROOT}/scripts/webrtc_camera_receiver.py" \
      --host 0.0.0.0 \
      --port "${WEBRTC_SIGNAL_PORT:-8765}" \
      --duration "${WEBRTC_DURATION:-86400}" \
      --cmd-rate "${cmd_rate}" \
      --cmd-linear-x "${CMD_LINEAR_X:-0.0}" \
      --cmd-angular-z "${CMD_ANGULAR_Z:-0.0}" \
      "${optional_args[@]}" \
      --json "${RUN_DIR}/webrtc_${role}_summary.json" \
      --csv "${RUN_DIR}/webrtc_${role}_latency.csv"
  else
    launch_webrtc_receiver_h264_streams "${role}" "${py}" "${target}" "${cmd_rate}"
  fi
}

launch_signal_relay() {
  local py
  local relay_auth_args=()
  py="$(signal_python_bin)"
  if [[ -n "${HORUS_WEBRTC_RELAY_TOKEN:-}" ]]; then
    relay_auth_args+=(--auth-token "${HORUS_WEBRTC_RELAY_TOKEN}")
  elif [[ "${HORUS_WEBRTC_RELAY_ALLOW_UNAUTHENTICATED:-0}" == "1" ]]; then
    relay_auth_args+=(--allow-unauthenticated)
  fi
  start_bg signal "${py}" "${ROOT}/scripts/webrtc_signal_relay.py" \
    --host 0.0.0.0 \
    --port "${WEBRTC_SIGNAL_PORT:-8765}" \
    --state-file "${RUN_DIR}/signal_members.json" \
    "${relay_auth_args[@]}"
}

launch_metrics() {
  if [[ -z "${HORUS_METRICS_PORT:-}" || "${HORUS_METRICS_PORT:-0}" == "0" ]]; then
    return
  fi
  start_bg metrics python3 "${ROOT}/scripts/horus_metrics.py" \
    --root "${ROOT}" \
    --env "${ENV_FILE}" \
    --host "${HORUS_METRICS_HOST:-127.0.0.1}" \
    --port "${HORUS_METRICS_PORT}"
}

launch_fake_data() {
  local robot_id="$1"
  local py="python3"
  source_ros_required
  start_bg fake-data "${py}" "${ROOT}/scripts/fake_robot_ros2_data.py" \
    --robot-id "${robot_id}" \
    --image-topic "${FAKE_ROS_IMAGE_TOPIC:-${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-/camera/image_raw}}" \
    --image-qos "${FAKE_ROS_IMAGE_QOS:-default}" \
    --odom-topic "${FAKE_ROS_ODOM_TOPIC:-/odom}" \
    --scan-topic "${FAKE_ROS_SCAN_TOPIC:-/scan}" \
    --joint-topic "${FAKE_ROS_JOINT_TOPIC:-/joint_states}" \
    --points-topic "${FAKE_ROS_POINTS_TOPIC:-/points}" \
    --width "${FAKE_CAMERA_WIDTH:-${WEBRTC_VIDEO_WIDTH:-1280}}" \
    --height "${FAKE_CAMERA_HEIGHT:-${WEBRTC_VIDEO_HEIGHT:-720}}" \
    --camera-fps "${FAKE_CAMERA_FPS:-${WEBRTC_VIDEO_FPS:-30}}" \
    --frame-cache "${FAKE_FRAME_CACHE:-30}" \
    --state-rate "${FAKE_STATE_RATE:-20}" \
    --points-rate "${FAKE_POINTS_RATE:-1}" \
    --point-count "${FAKE_POINT_COUNT:-512}" \
    --color-seed "${FAKE_COLOR_SEED:-17}"
}

launch_field_teammate() {
  local py="python3"
  local name="${FIELD_TEAMMATE_NAME:-${HORUS_ROOM:-field_teammate_1}}"
  local hololens_host="${FIELD_TEAMMATE_HOLOLENS_HOST:-${HOLOLENS_HOST:-}}"
  local relay_args=()

  required_value FIELD_TEAMMATE_HOLOLENS_HOST "${hololens_host}"
  source_ros_required

  relay_args+=(
    --name "${name}"
    --hololens-host "${hololens_host}"
    --pv-port "${FIELD_TEAMMATE_PV_PORT:-3810}"
    --spatial-input-port "${FIELD_TEAMMATE_SPATIAL_INPUT_PORT:-3814}"
    --umq-port "${FIELD_TEAMMATE_UMQ_PORT:-3816}"
    --map-frame "${FIELD_TEAMMATE_MAP_FRAME:-map}"
    --profile-height "${FIELD_TEAMMATE_PROFILE_HEIGHT:-1.75}"
    --camera-height "${FIELD_TEAMMATE_CAMERA_HEIGHT:-0.0}"
    --floor-height "${FIELD_TEAMMATE_FLOOR_HEIGHT:-0.0}"
    --pose-origin "${FIELD_TEAMMATE_POSE_ORIGIN:-camera}"
    --connect-timeout "${FIELD_TEAMMATE_CONNECT_TIMEOUT:-2.0}"
    --reconnect-delay "${FIELD_TEAMMATE_RECONNECT_DELAY:-1.0}"
    --video-profile "${FIELD_TEAMMATE_VIDEO_PROFILE:-fast60}"
  )

  if [[ "${FIELD_TEAMMATE_RAW_IMAGE:-0}" == "1" ]]; then
    relay_args+=(--raw-image)
  else
    relay_args+=(--no-raw-image)
  fi
  [[ -n "${FIELD_TEAMMATE_VIDEO_MODE:-}" ]] && relay_args+=(--video-mode "${FIELD_TEAMMATE_VIDEO_MODE}")
  [[ -n "${FIELD_TEAMMATE_VIDEO_WIDTH:-}" ]] && relay_args+=(--video-width "${FIELD_TEAMMATE_VIDEO_WIDTH}")
  [[ -n "${FIELD_TEAMMATE_VIDEO_HEIGHT:-}" ]] && relay_args+=(--video-height "${FIELD_TEAMMATE_VIDEO_HEIGHT}")
  [[ -n "${FIELD_TEAMMATE_VIDEO_FPS:-}" ]] && relay_args+=(--video-fps "${FIELD_TEAMMATE_VIDEO_FPS}")
  [[ -n "${FIELD_TEAMMATE_VIDEO_QUALITY:-}" ]] && relay_args+=(--video-quality "${FIELD_TEAMMATE_VIDEO_QUALITY}")

  start_bg teammate "${py}" "${ROOT}/scripts/field_teammate_hololens_relay.py" "${relay_args[@]}"
}

cmd="${1:-help}"
case "${cmd}" in
  setup|configure)
    setup_args=("${@:2}")
    case "${2:-}" in
      robot|machine|teammate|cloud)
        setup_args=(--role "$2" "${@:3}")
        ;;
    esac
    python3 "${ROOT}/scripts/horus_setup.py" --root "${ROOT}" --env "${ENV_FILE}" "${setup_args[@]}"
    ;;
  init)
    print_banner
    echo -e "${BOLD}${FG_CYAN}Initialize configuration${RESET}"
    if [[ -f "${ENV_FILE}" ]]; then
      log_warn "Configuration already exists. No changes were made."
      echo -e "  file       ${FG_MUTED}${ENV_FILE}${RESET}"
      echo -e "  next       ${FG_CYAN}./horus setup${RESET}"
    else
      cp "${ROOT}/.env.example" "${ENV_FILE}"
      log_success "Configuration created."
      echo -e "  file       ${FG_GREEN}${ENV_FILE}${RESET}"
      echo ""
      echo -e "${BOLD}Next commands${RESET}"
      echo -e "  ${FG_CYAN}./horus setup${RESET}"
      echo -e "  ${FG_CYAN}./horus bootstrap <role>${RESET}"
      echo -e "  ${FG_CYAN}./horus launch <role>${RESET}"
    fi
    echo ""
    ;;
  bootstrap)
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  boostrap|bootsrap)
    log_warn "Interpreting '${cmd}' as 'bootstrap'."
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  launch)
    load_env
    role="${2:-${HORUS_ROLE:-robot}}"
    no_monitor=0
    for arg in "${@:3}"; do
      case "${arg}" in
        --no-monitor) no_monitor=1 ;;
        *) echo "Unknown launch option: ${arg}" >&2; exit 2 ;;
      esac
    done
    case "${role}" in
      robot|machine)
        ensure_webrtc_media_supported
        warn_runtime_config
        ;;
      teammate|cloud)
        ;;
      fleet)
        log_error "'fleet' is managed with the fleet command, not launch."
        echo -e "Use: ${FG_CYAN}./horus fleet launch config/fleet.example.json${RESET}" >&2
        exit 2
        ;;
      *)
        log_error "Unknown launch role: ${role}"
        echo -e "Supported roles: ${FG_CYAN}robot${RESET}, ${FG_CYAN}machine${RESET}, ${FG_CYAN}teammate${RESET}, ${FG_CYAN}cloud${RESET}" >&2
        exit 2
        ;;
    esac
    print_banner
    echo -e "${BOLD}${FG_CYAN}Launch ${role}${RESET} ${FG_MUTED}$(date '+%Y-%m-%d %H:%M:%S')${RESET}"
    echo -e "  role       ${BOLD}${role}${RESET}"
    echo -e "  topology   ${HORUS_TOPOLOGY:-hub}"
    echo -e "  room       ${HORUS_ROOM:-default}"
    echo -e "  config     ${ENV_FILE}"
    zenoh_target="$(zenoh_connect_target "${role}")"
    if [[ -n "${zenoh_target}" ]]; then
      echo -e "  zenoh      ${ZENOH_BRIDGE_RUNTIME:-binary}, ${FG_CYAN}$(zenoh_connect_summary "${zenoh_target}")${RESET}, namespace ${FG_CYAN}${ZENOH_NAMESPACE:-/}${RESET}"
    else
      echo -e "  zenoh      ${ZENOH_BRIDGE_RUNTIME:-binary}, listening ${FG_CYAN}$(zenoh_listen_summary)${RESET}, namespace ${FG_CYAN}${ZENOH_NAMESPACE:-/}${RESET}"
    fi
    echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
    if [[ "${role}" == "teammate" ]]; then
      echo -e "  relay      HoloLens TCP -> local ROS 2 -> Zenoh"
    else
      echo -e "  signal     ws://$(webrtc_signal_target):${WEBRTC_SIGNAL_PORT:-8765}"
    fi
    if [[ "${role}" == "cloud" ]]; then
      if turn_enabled; then
        echo -e "  turn       ${FG_CYAN}enabled${RESET}, udp/tcp ${TURN_PORT:-3478}, relay ${TURN_MIN_PORT:-49152}-${TURN_MAX_PORT:-65535}"
      else
        echo -e "  turn       ${FG_MUTED}disabled${RESET}"
      fi
    elif [[ "${role}" != "teammate" && ( "${WEBRTC_ICE_SERVERS:-}" == *"turn:"* || "${WEBRTC_ICE_SERVERS:-}" == *"turns:"* ) ]]; then
      echo -e "  turn       ${FG_CYAN}fallback configured${RESET}"
    fi
    if [[ "${role}" == "teammate" ]]; then
      echo -e "  teammate  ${FG_CYAN}${FIELD_TEAMMATE_NAME:-${HORUS_ROOM:-field_teammate_1}}${RESET}"
      echo -e "  hololens  ${FG_CYAN}${FIELD_TEAMMATE_HOLOLENS_HOST:-${HOLOLENS_HOST:-unset}}${RESET}"
      echo -e "  fpv        ${FG_CYAN}${FIELD_TEAMMATE_VIDEO_PROFILE:-fast60}${RESET}, ROS compressed image"
    else
      if [[ "$(webrtc_control_enabled)" == "1" ]]; then
        echo -e "  control    ${FG_YELLOW}WebRTC DataChannel enabled${RESET}, ROS topic ${ROS_CMD_TOPIC:-/cmd_vel}"
      else
        echo -e "  control    ${FG_GREEN}ROS/Zenoh cmd_vel${RESET}, WebRTC video only"
      fi
      echo -e "  media      ${FG_CYAN}${WEBRTC_MEDIA_MODE:-h264}${RESET}"
    fi
    if [[ "${role}" != "teammate" && "${WEBRTC_MEDIA_MODE:-h264}" == "h264" ]]; then
      echo -e "  stream     ${FG_CYAN}${WEBRTC_VIDEO_WIDTH:-1280}x${WEBRTC_VIDEO_HEIGHT:-720}${RESET} @ ${FG_CYAN}${WEBRTC_VIDEO_FPS:-30} fps${RESET}, source ${WEBRTC_VIDEO_SOURCE:-ros2}"
      echo -e "  ros image  ${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-/camera/image_raw}"
      if [[ "${role}" == "robot" || "${role}" == "machine" ]]; then
        print_webrtc_stream_summary "${role}"
      fi
    fi
    echo -e "  ros        ${ROS_DISTRO:-jazzy}, domain ${FG_CYAN}${ROS_DOMAIN_ID:-0}${RESET}"
    echo ""

    log_info "Starting services for role: ${BOLD}${role}${RESET}"
    case "${role}" in
      robot)
        if zenoh_enabled; then
          launch_zenoh_client robot "$(zenoh_connect_target robot)"
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        launch_webrtc_robot
        ;;
      machine)
        if zenoh_enabled; then
          if [[ "${HORUS_TOPOLOGY:-hub}" == "direct" ]]; then
            launch_zenoh_router machine
          else
            launch_zenoh_client machine "$(zenoh_connect_target machine)"
          fi
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        launch_webrtc_receiver machine
        ;;
      teammate)
        if zenoh_enabled; then
          launch_zenoh_client teammate "$(zenoh_connect_target teammate)"
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        launch_field_teammate
        ;;
      cloud)
        if zenoh_enabled; then
          launch_zenoh_router cloud
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        if [[ "${HORUS_CLOUD_RUN_SIGNALING:-1}" == "1" ]]; then
          launch_signal_relay
        fi
        start_turn_relay
        ;;
      *)
        echo "Unknown launch role: ${role}" >&2
        exit 2
        ;;
    esac
    launch_metrics
    open_monitor_after_launch "${no_monitor}"
    ;;
  stop)
    load_env
    print_banner
    echo -e "${BOLD}${FG_CYAN}Stop services${RESET}"

    stop_one_styled() {
      local name="$1"
      local pid="${RUN_DIR}/${name}.pid"
      if [[ -f "${pid}" ]]; then
        if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
          echo -e "  ${name}       stopping PID $(cat "${pid}")"
          kill "$(cat "${pid}")" || true
          sleep 1
          if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
            kill -KILL "$(cat "${pid}")" || true
          fi
          echo -e "  ${name}       ${FG_GREEN}stopped${RESET}"
        else
          echo -e "  ${name}       ${FG_MUTED}not running${RESET}"
        fi
        rm -f "${pid}"
      else
        echo -e "  ${name}       ${FG_MUTED}already stopped${RESET}"
      fi
    }

    stop_one_styled webrtc
    for stream_pid in "${RUN_DIR}"/webrtc-*.pid; do
      [[ -e "${stream_pid}" ]] || continue
      stop_one_styled "$(basename "${stream_pid}" .pid)"
    done
    stop_one_styled signal
    rm -f "${RUN_DIR}/signal_members.json"
    if turn_enabled; then
      echo -e "  turn        stopping $(turn_service_name)"
      stop_turn_relay
      if turn_running; then
        echo -e "  turn        ${FG_YELLOW}still running${RESET}"
      else
        echo -e "  turn        ${FG_GREEN}stopped${RESET}"
      fi
    else
      echo -e "  turn        ${FG_MUTED}disabled${RESET}"
    fi
    stop_one_styled metrics
    stop_one_styled teammate
    stop_one_styled fake-data

    if [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]; then
      docker_cmd=(docker)
      [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
      name="$(zenoh_docker_name "${HORUS_ROLE:-robot}")"
      if "${docker_cmd[@]}" ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${name}$"; then
        echo -e "  docker      stopping ${name}"
        "${docker_cmd[@]}" rm -f "${name}" >/dev/null 2>&1 || true
        echo -e "  docker      ${FG_GREEN}removed${RESET}"
      fi
    fi

    stop_one_styled zenoh

    echo -e "  cleanup     stale connector processes"
    stop_stale_project_processes
    echo -e "  cleanup     ${FG_GREEN}complete${RESET}"

    log_success "All services are stopped."
    echo ""
    ;;
  status)
    load_env
    if [[ "${2:-}" == "--json" ]]; then
      python3 "${ROOT}/scripts/horus_monitor.py" --root "${ROOT}" --env "${ENV_FILE}" --json
      exit 0
    fi
    print_banner
    echo -e "${BOLD}${FG_CYAN}Status${RESET} ${FG_MUTED}$(date '+%H:%M:%S')${RESET}"
    echo -e "  role       ${BOLD}${HORUS_ROLE:-robot}${RESET}"
    echo -e "  topology   ${HORUS_TOPOLOGY:-hub}"
    echo -e "  room       ${HORUS_ROOM:-default}"
    distro="${ROS_DISTRO:-jazzy}"
    domain="${ROS_DOMAIN_ID:-0}"
    ns="${ZENOH_NAMESPACE:-/}"
    echo -e "  ros        ${FG_CYAN}${distro}${RESET}, domain ${FG_CYAN}${domain}${RESET}, namespace ${FG_CYAN}${ns}${RESET}"
    if [[ "${HORUS_ROLE:-robot}" == "teammate" ]]; then
      echo -e "  teammate  ${FG_CYAN}${FIELD_TEAMMATE_NAME:-${HORUS_ROOM:-field_teammate_1}}${RESET}"
      echo -e "  hololens  ${FG_CYAN}${FIELD_TEAMMATE_HOLOLENS_HOST:-${HOLOLENS_HOST:-unset}}${RESET}"
      echo -e "  fpv        ${FG_CYAN}${FIELD_TEAMMATE_VIDEO_PROFILE:-fast60}${RESET}"
    else
      echo -e "  media      ${FG_CYAN}${WEBRTC_MEDIA_MODE:-h264}${RESET}"
      if [[ "$(webrtc_control_enabled)" == "1" ]]; then
        echo -e "  control    ${FG_YELLOW}WebRTC DataChannel${RESET}"
      else
        echo -e "  control    ${FG_GREEN}ROS/Zenoh cmd_vel${RESET}"
      fi
    fi
    if [[ "${HORUS_ROLE:-robot}" != "teammate" && "${WEBRTC_MEDIA_MODE:-h264}" == "h264" ]]; then
      echo -e "  stream     ${FG_CYAN}${WEBRTC_VIDEO_WIDTH:-1280}x${WEBRTC_VIDEO_HEIGHT:-720} @ ${WEBRTC_VIDEO_FPS:-30} fps${RESET}"
      echo -e "  source     ${FG_CYAN}${WEBRTC_VIDEO_SOURCE:-ros2}${RESET}"
      if [[ "${WEBRTC_VIDEO_SOURCE:-ros2}" == "ros2" ]]; then
        echo -e "  image in   ${FG_CYAN}${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-/camera/image_raw}${RESET}"
      fi
      if [[ "${HORUS_ROLE:-robot}" == "robot" || "${HORUS_ROLE:-robot}" == "machine" ]]; then
        print_webrtc_stream_summary "${HORUS_ROLE:-robot}"
      fi
    fi
    zenoh_target="$(zenoh_connect_target "${HORUS_ROLE:-robot}")"
    if [[ -n "${zenoh_target}" ]]; then
      echo -e "  zenoh      $(zenoh_connect_summary "${zenoh_target}")"
    else
      echo -e "  zenoh      listening $(zenoh_listen_summary)"
    fi
    echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
    if [[ "${HORUS_ROLE:-robot}" == "teammate" ]]; then
      echo -e "  relay      HoloLens TCP -> local ROS 2 -> Zenoh"
    else
      echo -e "  signal     ws://$(webrtc_signal_target):${WEBRTC_SIGNAL_PORT:-8765}"
    fi
    if [[ -f "${ROOT}/.webrtc_profile.env" ]]; then
      load_key_value_file "${ROOT}/.webrtc_profile.env"
      encoder="${GST_H264_ENCODER_NAME:-unknown}"
      decoder="${GST_H264_DECODER_NAME:-unknown}"
      accel="${VIDEO_ENCODER_ACCEL:-${VIDEO_DECODER_ACCEL:-auto}}"
      echo -e "  codec      ${FG_CYAN}${encoder}${RESET} encode, ${FG_CYAN}${decoder}${RESET} decode (${accel})"
    fi
    echo ""
    echo -e "${BOLD}Services${RESET}"
    status_zenoh
    status_one signal
    status_turn
    if [[ "${HORUS_ROLE:-robot}" == "teammate" ]]; then
      status_one teammate
    else
      status_webrtc_streams
    fi
    status_one metrics
    status_one fake-data
    echo ""
    echo -e "${FG_MUTED}Run ${FG_CYAN}./horus monitor${RESET}${FG_MUTED} for the live console.${RESET}\n"
    ;;
  monitor|ui|watch)
    python3 "${ROOT}/scripts/horus_monitor.py" --root "${ROOT}" --env "${ENV_FILE}" "${@:2}"
    ;;
  metrics)
    load_env
    shift || true
    python3 "${ROOT}/scripts/horus_metrics.py" --root "${ROOT}" --env "${ENV_FILE}" "$@"
    ;;
  fleet)
    load_env
    if [[ -z "${2:-}" ]]; then
      python3 "${ROOT}/scripts/horus_fleet.py" --root "${ROOT}" --base-env "${ENV_FILE}" --help
      exit 2
    fi
    python3 "${ROOT}/scripts/horus_fleet.py" --root "${ROOT}" --base-env "${ENV_FILE}" "${@:2}"
    ;;
  fake-data)
    load_env
    robot_id="${2:-${FAKE_DATA_ROBOT_ID:-${HORUS_ROOM:-robot-a}}}"
    print_banner
    echo -e "${BOLD}${FG_CYAN}Fake ROS 2 data${RESET}"
    echo -e "  robot      ${robot_id}"
    launch_fake_data "${robot_id}"
    ;;
  doctor)
    load_env
    print_banner
    role="${2:-${HORUS_ROLE:-robot}}"
    doctor "${role}"
    ;;
  quic)
    load_env
    action="${2:-status}"
    case "${action}" in
      setup-server|server)
        "${ROOT}/scripts/setup_zenoh_tls.sh" server
        ;;
      install-cert|client)
        "${ROOT}/scripts/setup_zenoh_tls.sh" client "${3:-}"
        ;;
      status)
        "${ROOT}/scripts/setup_zenoh_tls.sh" status
        ;;
      export-cert)
        if [[ -n "${ZENOH_TLS_LISTEN_CERT:-}" && -f "${ZENOH_TLS_LISTEN_CERT/#\~/${HOME}}" ]]; then
          echo "${ZENOH_TLS_LISTEN_CERT/#\~/${HOME}}"
        else
          log_error "No local Zenoh listener certificate found. Run './horus quic setup-server' on the hub/listener."
          exit 1
        fi
        ;;
      *)
        log_error "Invalid quic action."
        echo -e "${BOLD}Usage:${RESET}"
        echo -e "  ./horus quic ${FG_GREEN}setup-server${RESET}"
        echo -e "  ./horus quic ${FG_GREEN}install-cert <cert.pem>${RESET}"
        echo -e "  ./horus quic ${FG_GREEN}status${RESET}"
        echo -e "  ./horus quic ${FG_GREEN}export-cert${RESET}\n"
        exit 2
        ;;
    esac
    ;;
  logs)
    service="${2:-}"
    case "${service}" in
      turn)
        print_banner
        echo -e "${BOLD}${FG_CYAN}Log stream: turn${RESET}"
        echo -e "  service    $(turn_service_name)"
        echo -e "  control    Press ${BOLD}Ctrl+C${RESET} to stop"
        echo ""
        if command -v journalctl >/dev/null 2>&1; then
          journalctl -u "$(turn_service_name)" -n 80 -f
        elif [[ -r /var/log/turnserver.log ]]; then
          tail -f /var/log/turnserver.log
        elif sudo -n test -r /var/log/turnserver.log >/dev/null 2>&1; then
          sudo -n tail -f /var/log/turnserver.log
        else
          log_error "TURN log is not readable. Try: sudo journalctl -u $(turn_service_name) -f"
          exit 1
        fi
        ;;
      zenoh|webrtc|webrtc-*|signal|metrics|teammate|fake-data)
      print_banner
        log_file="${RUN_DIR}/${service}.log"
        size_bytes=0
        line_count=0
        mod_time="unknown"
        if [[ -f "${log_file}" ]]; then
          size_bytes=$(wc -c < "${log_file}" 2>/dev/null || echo 0)
          line_count=$(wc -l < "${log_file}" 2>/dev/null || echo 0)
          mod_time=$(date -r "${log_file}" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || stat -c %y "${log_file}" 2>/dev/null | cut -d. -f1 || echo "unknown")
        fi

        status_text="${FG_MUTED}stopped${RESET}"
        pid_val=""
        if [[ -f "${RUN_DIR}/${service}.pid" ]]; then
          p_id=$(cat "${RUN_DIR}/${service}.pid" 2>/dev/null || echo "")
          if [[ -n "${p_id}" ]] && kill -0 "${p_id}" >/dev/null 2>&1; then
            status_text="${FG_GREEN}running${RESET}"
            pid_val=", PID ${p_id}"
          fi
        fi

        echo -e "${BOLD}${FG_CYAN}Log stream: ${service}${RESET}"
        echo -e "  file       ${FG_MUTED}${log_file}${RESET}"
        echo -e "  service    ${status_text}${FG_MUTED}${pid_val}${RESET}"
        fmt_size=$(numfmt --to=iec-i --suffix=B "${size_bytes}" 2>/dev/null || echo "${size_bytes} bytes")
        echo -e "  size       ${fmt_size} (${line_count} lines)"
        echo -e "  modified   ${mod_time}"
        echo -e "  control    Press ${BOLD}Ctrl+C${RESET} to stop"
        echo ""
        tail -f "${log_file}"
        ;;
      *)
        log_error "Invalid service specified."
        echo -e "${BOLD}Usage:${RESET}"
        echo -e "  ./horus logs ${FG_GREEN}[zenoh|webrtc|webrtc-<stream>|signal|turn|metrics|teammate|fake-data]${RESET}\n" >&2
        exit 2
        ;;
    esac
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
