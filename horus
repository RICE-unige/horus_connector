cmd="${1:-help}"
case "${cmd}" in
  setup|configure)
    python3 "${ROOT}/scripts/horus_setup.py" --root "${ROOT}" --env "${ENV_FILE}" "${@:2}"
    ;;
  init)
    print_banner
    echo -e "${BOLD}${FG_CYAN}Initialize configuration${RESET}"
    if [[ -f "${ENV_FILE}" ]]; then
      log_warn "Configuration already exists. No changes were made."
      echo -e "  file       ${FG_MUTED}${ENV_FILE}${RESET}"
      echo -e "  next       ${FG_CYAN}./horus setup${RESET}"
    else
      cp "${ROOT}/.env.example" "${ENV_FILE}"
      log_success "Configuration created."
      echo -e "  file       ${FG_GREEN}${ENV_FILE}${RESET}"
      echo ""
      echo -e "${BOLD}Next commands${RESET}"
      echo -e "  ${FG_CYAN}./horus setup${RESET}"
      echo -e "  ${FG_CYAN}./horus bootstrap <role>${RESET}"
      echo -e "  ${FG_CYAN}./horus launch <role>${RESET}"
    fi
    echo ""
    ;;
  bootstrap)
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  boostrap|bootsrap)
    log_warn "Interpreting '${cmd}' as 'bootstrap'."
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  launch)
    load_env
    role="${2:-${HORUS_ROLE:-robot}}"
    no_monitor=0
    for arg in "${@:3}"; do
      case "${arg}" in
        --no-monitor) no_monitor=1 ;;
        *) echo "Unknown launch option: ${arg}" >&2; exit 2 ;;
      esac
    done
    case "${role}" in
      robot|machine)
        ensure_webrtc_media_supported
        warn_runtime_config
        ;;
      cloud)
        ;;
      fleet)
        log_error "'fleet' is managed with the fleet command, not launch."
        echo -e "Use: ${FG_CYAN}./horus fleet launch config/fleet.example.json${RESET}" >&2
        exit 2
        ;;
      *)
        log_error "Unknown launch role: ${role}"
        echo -e "Supported roles: ${FG_CYAN}robot${RESET}, ${FG_CYAN}machine${RESET}, ${FG_CYAN}cloud${RESET}" >&2
        exit 2
        ;;
    esac
    print_banner
    echo -e "${BOLD}${FG_CYAN}Launch ${role}${RESET} ${FG_MUTED}$(date '+%Y-%m-%d %H:%M:%S')${RESET}"
    echo -e "  role       ${BOLD}${role}${RESET}"
    echo -e "  topology   ${HORUS_TOPOLOGY:-hub}"
    echo -e "  room       ${HORUS_ROOM:-default}"
    echo -e "  config     ${ENV_FILE}"
    zenoh_target="$(zenoh_connect_target "${role}")"
    if [[ -n "${zenoh_target}" ]]; then
      echo -e "  zenoh      ${ZENOH_BRIDGE_RUNTIME:-binary}, tcp/${zenoh_target}:${FG_CYAN}${ZENOH_PORT:-7447}${RESET}, namespace ${FG_CYAN}${ZENOH_NAMESPACE:-/}${RESET}"
    else
      echo -e "  zenoh      ${ZENOH_BRIDGE_RUNTIME:-binary}, listening tcp/0.0.0.0:${FG_CYAN}${ZENOH_PORT:-7447}${RESET}, namespace ${FG_CYAN}${ZENOH_NAMESPACE:-/}${RESET}"
    fi
    echo -e "  signal     ws://$(webrtc_signal_target):${WEBRTC_SIGNAL_PORT:-8765}"
    if [[ "${role}" == "cloud" ]]; then
      if turn_enabled; then
        echo -e "  turn       ${FG_CYAN}enabled${RESET}, udp/tcp ${TURN_PORT:-3478}, relay ${TURN_MIN_PORT:-49152}-${TURN_MAX_PORT:-65535}"
      else
        echo -e "  turn       ${FG_MUTED}disabled${RESET}"
      fi
    elif [[ "${WEBRTC_ICE_SERVERS:-}" == *"turn:"* || "${WEBRTC_ICE_SERVERS:-}" == *"turns:"* ]]; then
      echo -e "  turn       ${FG_CYAN}fallback configured${RESET}"
    fi
    echo -e "  media      ${FG_CYAN}${WEBRTC_MEDIA_MODE:-h264}${RESET}"
    if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "h264" ]]; then
      echo -e "  stream     ${FG_CYAN}${WEBRTC_VIDEO_WIDTH:-1280}x${WEBRTC_VIDEO_HEIGHT:-720}${RESET} @ ${FG_CYAN}${WEBRTC_VIDEO_FPS:-30} fps${RESET}, source ${WEBRTC_VIDEO_SOURCE:-ros2}"
      echo -e "  ros image  ${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-/camera/image_raw}"
    fi
    echo -e "  ros        ${ROS_DISTRO:-jazzy}, domain ${FG_CYAN}${ROS_DOMAIN_ID:-0}${RESET}"
    echo ""

    log_info "Starting services for role: ${BOLD}${role}${RESET}"
    case "${role}" in
      robot)
        if zenoh_enabled; then
          launch_zenoh_client robot "$(zenoh_connect_target robot)"
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        launch_webrtc_robot
        ;;
      machine)
        if zenoh_enabled; then
          if [[ "${HORUS_TOPOLOGY:-hub}" == "direct" ]]; then
            launch_zenoh_router machine
          else
            launch_zenoh_client machine "$(zenoh_connect_target machine)"
          fi
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        launch_webrtc_receiver machine
        ;;
      cloud)
        if zenoh_enabled; then
          launch_zenoh_router cloud
        else
          log_warn "Zenoh is disabled for this launch."
        fi
        if [[ "${HORUS_CLOUD_RUN_SIGNALING:-1}" == "1" ]]; then
          launch_signal_relay
        fi
        start_turn_relay
        ;;
      *)
        echo "Unknown launch role: ${role}" >&2
        exit 2
        ;;
    esac
    launch_metrics
    open_monitor_after_launch "${no_monitor}"
    ;;
  stop)
    load_env
    print_banner
    echo -e "${BOLD}${FG_CYAN}Stop services${RESET}"

    stop_one_styled() {
      local name="$1"
      local pid="${RUN_DIR}/${name}.pid"
      if [[ -f "${pid}" ]]; then
        if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
          echo -e "  ${name}       stopping PID $(cat "${pid}")"
          kill "$(cat "${pid}")" || true
          sleep 1
          if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
            kill -KILL "$(cat "${pid}")" || true
          fi
          echo -e "  ${name}       ${FG_GREEN}stopped${RESET}"
        else
          echo -e "  ${name}       ${FG_MUTED}not running${RESET}"
        fi
        rm -f "${pid}"
      else
        echo -e "  ${name}       ${FG_MUTED}already stopped${RESET}"
      fi
    }

    stop_one_styled webrtc
    stop_one_styled signal
    rm -f "${RUN_DIR}/signal_members.json"
    if turn_enabled; then
      echo -e "  turn        stopping $(turn_service_name)"
      stop_turn_relay
      if turn_running; then
        echo -e "  turn        ${FG_YELLOW}still running${RESET}"
      else
        echo -e "  turn        ${FG_GREEN}stopped${RESET}"
      fi
    else
      echo -e "  turn        ${FG_MUTED}disabled${RESET}"
    fi
    stop_one_styled metrics
    stop_one_styled fake-data

    if [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]; then
      docker_cmd=(docker)
      [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
      name="$(zenoh_docker_name "${HORUS_ROLE:-robot}")"
      if "${docker_cmd[@]}" ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${name}$"; then
        echo -e "  docker      stopping ${name}"
        "${docker_cmd[@]}" rm -f "${name}" >/dev/null 2>&1 || true
        echo -e "  docker      ${FG_GREEN}removed${RESET}"
      fi
    fi

    stop_one_styled zenoh

    echo -e "  cleanup     stale connector processes"
    stop_stale_project_processes
    echo -e "  cleanup     ${FG_GREEN}complete${RESET}"

    log_success "All services are stopped."
    echo ""
    ;;
  status)
    load_env
    if [[ "${2:-}" == "--json" ]]; then
      python3 "${ROOT}/scripts/horus_monitor.py" --root "${ROOT}" --env "${ENV_FILE}" --json
      exit 0
    fi
    print_banner
    echo -e "${BOLD}${FG_CYAN}Status${RESET} ${FG_MUTED}$(date '+%H:%M:%S')${RESET}"
    echo -e "  role       ${BOLD}${HORUS_ROLE:-robot}${RESET}"
    echo -e "  topology   ${HORUS_TOPOLOGY:-hub}"
    echo -e "  room       ${HORUS_ROOM:-default}"
    distro="${ROS_DISTRO:-jazzy}"
    domain="${ROS_DOMAIN_ID:-0}"
    ns="${ZENOH_NAMESPACE:-/}"
    echo -e "  ros        ${FG_CYAN}${distro}${RESET}, domain ${FG_CYAN}${domain}${RESET}, namespace ${FG_CYAN}${ns}${RESET}"
    echo -e "  media      ${FG_CYAN}${WEBRTC_MEDIA_MODE:-h264}${RESET}"
    if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "h264" ]]; then
      echo -e "  stream     ${FG_CYAN}${WEBRTC_VIDEO_WIDTH:-1280}x${WEBRTC_VIDEO_HEIGHT:-720} @ ${WEBRTC_VIDEO_FPS:-30} fps${RESET}"
      echo -e "  source     ${FG_CYAN}${WEBRTC_VIDEO_SOURCE:-ros2}${RESET}"
      if [[ "${WEBRTC_VIDEO_SOURCE:-ros2}" == "ros2" ]]; then
        echo -e "  image in   ${FG_CYAN}${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-/camera/image_raw}${RESET}"
      fi
    fi
    zenoh_target="$(zenoh_connect_target "${HORUS_ROLE:-robot}")"
    if [[ -n "${zenoh_target}" ]]; then
      echo -e "  zenoh      tcp/${zenoh_target}:${ZENOH_PORT:-7447}"
    else
      echo -e "  zenoh      listening tcp/0.0.0.0:${ZENOH_PORT:-7447}"
    fi
    echo -e "  signal     ws://$(webrtc_signal_target):${WEBRTC_SIGNAL_PORT:-8765}"
    if [[ -f "${ROOT}/.webrtc_profile.env" ]]; then
      set -a
      # shellcheck source=/dev/null
      source "${ROOT}/.webrtc_profile.env"
      set +a
      encoder="${GST_H264_ENCODER_NAME:-unknown}"
      decoder="${GST_H264_DECODER_NAME:-unknown}"
      accel="${VIDEO_ENCODER_ACCEL:-${VIDEO_DECODER_ACCEL:-auto}}"
      echo -e "  codec      ${FG_CYAN}${encoder}${RESET} encode, ${FG_CYAN}${decoder}${RESET} decode (${accel})"
    fi
    echo ""
    echo -e "${BOLD}Services${RESET}"
    status_zenoh
    status_one signal
    status_turn
    status_one webrtc
    status_one metrics
    status_one fake-data
    echo ""
    echo -e "${FG_MUTED}Run ${FG_CYAN}./horus monitor${RESET}${FG_MUTED} for the live console.${RESET}\n"
    ;;
  monitor|ui|watch)
    python3 "${ROOT}/scripts/horus_monitor.py" --root "${ROOT}" --env "${ENV_FILE}" "${@:2}"
    ;;
  metrics)
    load_env
    shift || true
    python3 "${ROOT}/scripts/horus_metrics.py" --root "${ROOT}" --env "${ENV_FILE}" "$@"
    ;;
  fleet)
    load_env
    if [[ -z "${2:-}" ]]; then
      python3 "${ROOT}/scripts/horus_fleet.py" --root "${ROOT}" --base-env "${ENV_FILE}" --help
      exit 2
    fi
    python3 "${ROOT}/scripts/horus_fleet.py" --root "${ROOT}" --base-env "${ENV_FILE}" "${@:2}"
    ;;
  fake-data)
    load_env
    robot_id="${2:-${FAKE_DATA_ROBOT_ID:-${HORUS_ROOM:-robot-a}}}"
    print_banner
    echo -e "${BOLD}${FG_CYAN}Fake ROS 2 data${RESET}"
    echo -e "  robot      ${robot_id}"
    launch_fake_data "${robot_id}"
    ;;
  doctor)
    load_env
    print_banner
    role="${2:-${HORUS_ROLE:-robot}}"
    doctor "${role}"
    ;;
  logs)
    service="${2:-}"
    case "${service}" in
      turn)
        print_banner
        echo -e "${BOLD}${FG_CYAN}Log stream: turn${RESET}"
        echo -e "  service    $(turn_service_name)"
        echo -e "  control    Press ${BOLD}Ctrl+C${RESET} to stop"
        echo ""
        if command -v journalctl >/dev/null 2>&1; then
          journalctl -u "$(turn_service_name)" -n 80 -f
        elif [[ -r /var/log/turnserver.log ]]; then
          tail -f /var/log/turnserver.log
        elif sudo -n test -r /var/log/turnserver.log >/dev/null 2>&1; then
          sudo -n tail -f /var/log/turnserver.log
        else
          log_error "TURN log is not readable. Try: sudo journalctl -u $(turn_service_name) -f"
          exit 1
        fi
        ;;
      zenoh|webrtc|signal|metrics|fake-data)
      print_banner
        log_file="${RUN_DIR}/${service}.log"
        size_bytes=0
        line_count=0
        mod_time="unknown"
        if [[ -f "${log_file}" ]]; then
          size_bytes=$(wc -c < "${log_file}" 2>/dev/null || echo 0)
          line_count=$(wc -l < "${log_file}" 2>/dev/null || echo 0)
          mod_time=$(date -r "${log_file}" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || stat -c %y "${log_file}" 2>/dev/null | cut -d. -f1 || echo "unknown")
        fi

        status_text="${FG_MUTED}stopped${RESET}"
        pid_val=""
        if [[ -f "${RUN_DIR}/${service}.pid" ]]; then
          p_id=$(cat "${RUN_DIR}/${service}.pid" 2>/dev/null || echo "")
          if [[ -n "${p_id}" ]] && kill -0 "${p_id}" >/dev/null 2>&1; then
            status_text="${FG_GREEN}running${RESET}"
            pid_val=", PID ${p_id}"
          fi
        fi

        echo -e "${BOLD}${FG_CYAN}Log stream: ${service}${RESET}"
        echo -e "  file       ${FG_MUTED}${log_file}${RESET}"
        echo -e "  service    ${status_text}${FG_MUTED}${pid_val}${RESET}"
        fmt_size=$(numfmt --to=iec-i --suffix=B "${size_bytes}" 2>/dev/null || echo "${size_bytes} bytes")
        echo -e "  size       ${fmt_size} (${line_count} lines)"
        echo -e "  modified   ${mod_time}"
        echo -e "  control    Press ${BOLD}Ctrl+C${RESET} to stop"
        echo ""
        tail -f "${log_file}"
        ;;
      *)
        log_error "Invalid service specified."
        echo -e "${BOLD}Usage:${RESET}"
        echo -e "  ./horus logs ${FG_GREEN}[zenoh|webrtc|signal|turn|metrics|fake-data]${RESET}\n" >&2
        exit 2
        ;;
    esac
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
