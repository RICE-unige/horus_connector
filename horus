#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUN_DIR="${ROOT}/.run"
ENV_FILE="${HORUS_ENV:-${ROOT}/.env}"
mkdir -p "${RUN_DIR}"

usage() {
  cat <<'USAGE'
Usage:
  ./horus init
  ./horus bootstrap [robot|machine|cloud|auto]
  ./horus launch [robot|machine|cloud]
  ./horus stop
  ./horus status
  ./horus doctor [robot|machine|cloud]
  ./horus logs [zenoh|webrtc|signal]

Roles:
  robot    Robot-side system. Publishes camera over WebRTC and receives cmd_vel over WebRTC.
  machine  Operator/local machine. Receives WebRTC cameras and connects to robot state.
  cloud    Single shared relay/router for hub deployments.

Topologies:
  hub      robot(s) and machine(s) connect through one cloud Zenoh router.
  direct   robot connects directly to machine over VPN/Tailscale/LAN; no cloud required.

In hub mode the cloud runs Zenoh routing and WebRTC signaling relay only. Media
encoding/decoding happens on robot and machine endpoints.
USAGE
}

load_env() {
  if [[ ! -f "${ENV_FILE}" ]]; then
    echo "Missing ${ENV_FILE}. Run ./horus init first." >&2
    exit 1
  fi
  set -a
  # shellcheck source=/dev/null
  source "${ENV_FILE}"
  if [[ -f "${ROOT}/.zenoh_profile.env" ]]; then
    # shellcheck source=/dev/null
    source "${ROOT}/.zenoh_profile.env"
  fi
  set +a
}

source_ros() {
  local distro="${ROS_DISTRO:-jazzy}"
  if [[ -f "/opt/ros/${distro}/setup.bash" ]]; then
    set +u
    # shellcheck source=/dev/null
    source "/opt/ros/${distro}/setup.bash"
    set -u
  elif [[ -f "/opt/ros/${distro}/local_setup.bash" ]]; then
    set +u
    # shellcheck source=/dev/null
    source "/opt/ros/${distro}/local_setup.bash"
    set -u
  else
    echo "ROS setup file not found for ${distro}: /opt/ros/${distro}/setup.bash or local_setup.bash" >&2
    return 1
  fi
}

source_ros_required() {
  source_ros || exit 1
}

python_bin() {
  local py="${ROOT}/.venv-webrtc/bin/python"
  if [[ ! -x "${py}" ]]; then
    echo "python3"
    return
  fi

  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    if "${py}" - <<'PY' >/dev/null 2>&1
import aiortc
import numpy
import PIL
import websockets
PY
    then
      echo "${py}"
      return
    fi
  elif "${py}" - <<'PY' >/dev/null 2>&1
try:
    import websockets
except Exception:
    import websocket
PY
  then
    echo "${py}"
    return
  fi

  echo "python3"
}

signal_python_bin() {
  local py="${ROOT}/.venv-webrtc/bin/python"
  if [[ -x "${py}" ]] && "${py}" - <<'PY' >/dev/null 2>&1
import websockets
PY
  then
    echo "${py}"
    return
  fi

  echo "python3"
}

ice_args() {
  local args=()
  local ice="${WEBRTC_ICE_SERVERS:-stun:stun.l.google.com:19302}"
  IFS=',' read -ra servers <<< "${ice}"
  for server in "${servers[@]}"; do
    [[ -n "${server}" ]] && args+=(--ice-server "${server}")
  done
  printf '%q ' "${args[@]}"
}

required_value() {
  local name="$1"
  local value="$2"
  if [[ -z "${value}" ]]; then
    echo "${name} is not set in ${ENV_FILE}" >&2
    exit 1
  fi
}

zenoh_config_path() {
  echo "${ROOT}/${ZENOH_CONFIG:-config/zenoh_split.json5}"
}

zenoh_common_args() {
  local config
  config="$(zenoh_config_path)"
  [[ -f "${config}" ]] || { echo "Missing Zenoh config: ${config}" >&2; exit 1; }
  printf '%q ' -c "${config}"
  if [[ -n "${ZENOH_NAMESPACE:-}" ]]; then
    printf '%q ' -n "${ZENOH_NAMESPACE}"
  fi
}

zenoh_docker_cmd() {
  if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
    printf '%q ' sudo -n docker
  else
    printf '%q ' docker
  fi
}

zenoh_docker_name() {
  local role="$1"
  local room="${HORUS_ROOM:-default}"
  room="${room//[^A-Za-z0-9_.-]/_}"
  echo "horus-zenoh-${role}-${room}"
}

zenoh_uses_docker() {
  [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]
}

check_zenoh_docker_access() {
  local docker_cmd=(docker)
  if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
    docker_cmd=(sudo -n docker)
  fi

  if ! "${docker_cmd[@]}" ps >/dev/null 2>&1; then
    if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" && -t 0 ]]; then
      echo "Zenoh Docker fallback needs sudo; refreshing sudo credentials."
      sudo -v
      sudo docker ps >/dev/null 2>&1 && return
    fi
    if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
      echo "Zenoh Docker fallback needs sudo Docker access. Run 'sudo -v' before launch, or add this user to the docker group and log out/in." >&2
    else
      echo "Zenoh Docker fallback is configured, but Docker is not available to this user." >&2
    fi
    exit 1
  fi
}

zenoh_connect_target() {
  local role="$1"
  local topology="${HORUS_TOPOLOGY:-hub}"
  case "${role}:${topology}" in
    robot:hub|machine:hub)
      required_value HORUS_CLOUD_IP "${HORUS_CLOUD_IP:-}"
      echo "${HORUS_CLOUD_IP}"
      ;;
    robot:direct)
      required_value HORUS_MACHINE_IP "${HORUS_MACHINE_IP:-}"
      echo "${HORUS_MACHINE_IP}"
      ;;
    *)
      echo ""
      ;;
  esac
}

webrtc_signal_target() {
  if [[ -n "${HORUS_WEBRTC_SIGNAL_IP:-}" ]]; then
    echo "${HORUS_WEBRTC_SIGNAL_IP}"
  elif [[ -n "${HORUS_MACHINE_IP:-}" ]]; then
    echo "${HORUS_MACHINE_IP}"
  else
    required_value HORUS_CLOUD_IP "${HORUS_CLOUD_IP:-}"
    echo "${HORUS_CLOUD_IP}"
  fi
}

ensure_webrtc_media_supported() {
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" && "${HORUS_TOPOLOGY:-hub}" == "hub" ]]; then
    echo "WEBRTC_MEDIA_MODE=jpeg is the legacy direct-mode fallback and does not use the cloud signaling relay." >&2
    echo "Use WEBRTC_MEDIA_MODE=h264 for hub deployments, or HORUS_TOPOLOGY=direct for JPEG fallback tests." >&2
    exit 2
  fi
}

warn_runtime_config() {
  local duration="${WEBRTC_DURATION:-86400}"
  local duration_int="${duration%%.*}"
  if [[ "${duration_int}" =~ ^[0-9]+$ && "${duration_int}" -gt 0 && "${duration_int}" -lt 300 ]]; then
    echo "Warning: WEBRTC_DURATION=${duration} starts a short test session. Use 0 or 86400 for normal runs." >&2
  fi
}

tcp_probe() {
  local host="$1"
  local port="$2"
  if timeout 4 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1; then
    echo "open  tcp/${host}:${port}"
    return 0
  fi
  echo "closed tcp/${host}:${port}"
  return 1
}

doctor() {
  local role="$1"
  local target=""
  echo "Role: ${role}"
  echo "Topology: ${HORUS_TOPOLOGY:-hub}"
  echo "Room: ${HORUS_ROOM:-default}"
  warn_runtime_config

  case "${role}:${HORUS_TOPOLOGY:-hub}" in
    robot:direct)
      target="$(zenoh_connect_target robot)"
      echo "Direct target: ${target}"
      tcp_probe "${target}" "${ZENOH_PORT:-7447}" || true
      tcp_probe "$(webrtc_signal_target)" "${WEBRTC_SIGNAL_PORT:-8765}" || true
      ;;
    machine:direct)
      echo "Machine direct mode listens for robot connections."
      echo "Local addresses:"
      hostname -I 2>/dev/null || true
      echo "Expected listeners after launch: tcp/0.0.0.0:${ZENOH_PORT:-7447} and tcp/0.0.0.0:${WEBRTC_SIGNAL_PORT:-8765}"
      ss -ltnp 2>/dev/null | grep -E ":(${ZENOH_PORT:-7447}|${WEBRTC_SIGNAL_PORT:-8765})" || true
      ;;
    robot:hub|machine:hub)
      target="$(zenoh_connect_target "${role}")"
      echo "Cloud target: ${target}"
      tcp_probe "${target}" "${ZENOH_PORT:-7447}" || true
      tcp_probe "$(webrtc_signal_target)" "${WEBRTC_SIGNAL_PORT:-8765}" || true
      ;;
    cloud:*)
      echo "Cloud mode listens for robot and machine connections."
      ss -ltnp 2>/dev/null | grep -E ":(${ZENOH_PORT:-7447}|${WEBRTC_SIGNAL_PORT:-8765})" || true
      ;;
  esac
}

start_bg() {
  local name="$1"
  shift
  local log="${RUN_DIR}/${name}.log"
  local pid="${RUN_DIR}/${name}.pid"

  if [[ -f "${pid}" ]] && kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
    echo "${name} already running with pid $(cat "${pid}")"
    return
  fi

  echo "Starting ${name}; log: ${log}"
  nohup "$@" >"${log}" 2>&1 < /dev/null &
  echo "$!" > "${pid}"
}

stop_one() {
  local name="$1"
  local pid="${RUN_DIR}/${name}.pid"
  if [[ -f "${pid}" ]]; then
    if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
      kill "$(cat "${pid}")" || true
      sleep 1
      if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
        kill -KILL "$(cat "${pid}")" || true
      fi
      echo "Stopped ${name}"
    fi
    rm -f "${pid}"
  fi
}

project_pid_matches() {
  local pid="$1"
  local cwd cmdline
  [[ "${pid}" == "$$" ]] && return 1
  cwd="$(readlink -f "/proc/${pid}/cwd" 2>/dev/null || true)"
  cmdline="$(tr '\0' ' ' <"/proc/${pid}/cmdline" 2>/dev/null || true)"
  [[ "${cwd}" == "${ROOT}" || "${cmdline}" == *"${ROOT}/"* ]]
}

terminate_project_pids_by_pattern() {
  local signal="$1"
  shift
  local pattern pid
  for pattern in "$@"; do
    while IFS= read -r pid; do
      if project_pid_matches "${pid}"; then
        kill "-${signal}" "${pid}" >/dev/null 2>&1 || true
      fi
    done < <(pgrep -f "${pattern}" 2>/dev/null || true)
  done
}

terminate_project_pids_by_name() {
  local signal="$1"
  shift
  local name pid
  for name in "$@"; do
    while IFS= read -r pid; do
      if project_pid_matches "${pid}"; then
        kill "-${signal}" "${pid}" >/dev/null 2>&1 || true
      fi
    done < <(pgrep -x "${name}" 2>/dev/null || true)
  done
}

stop_stale_project_processes() {
  local patterns=(
    "${ROOT}/zenoh-bridge-ros2dds"
    "${ROOT}/scripts/gst_webrtc_h264_robot.py"
    "${ROOT}/scripts/gst_webrtc_h264_machine.py"
    "${ROOT}/scripts/webrtc_camera_sender.py"
    "${ROOT}/scripts/webrtc_camera_receiver.py"
    "${ROOT}/scripts/webrtc_signal_relay.py"
    "${ROOT}/scripts/fake_robot_ros2_data.py"
    "scripts/gst_webrtc_h264_robot.py"
    "scripts/gst_webrtc_h264_machine.py"
    "scripts/webrtc_camera_sender.py"
    "scripts/webrtc_camera_receiver.py"
    "scripts/webrtc_signal_relay.py"
    "scripts/fake_robot_ros2_data.py"
  )

  terminate_project_pids_by_pattern TERM "${patterns[@]}"
  sleep 1
  terminate_project_pids_by_pattern KILL "${patterns[@]}"
}

stop_zenoh() {
  if [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]; then
    local docker_cmd=(docker)
    [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
    "${docker_cmd[@]}" rm -f "$(zenoh_docker_name "${HORUS_ROLE:-robot}")" >/dev/null 2>&1 || true
  fi
  stop_one zenoh
  terminate_project_pids_by_name TERM zenoh-bridge-ros2dds
  sleep 1
  terminate_project_pids_by_name KILL zenoh-bridge-ros2dds
}

status_one() {
  local name="$1"
  local pid="${RUN_DIR}/${name}.pid"
  if [[ -f "${pid}" ]] && kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
    echo "${name}: running pid $(cat "${pid}")"
  else
    echo "${name}: stopped"
  fi
}

status_zenoh() {
  if [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]; then
    local docker_cmd=(docker)
    local status
    [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
    status="$("${docker_cmd[@]}" ps --filter "name=$(zenoh_docker_name "${HORUS_ROLE:-robot}")" --format '{{.Status}}' 2>/dev/null || true)"
    if [[ -n "${status}" ]]; then
      echo "zenoh: running container $(zenoh_docker_name "${HORUS_ROLE:-robot}") (${status})"
    else
      echo "zenoh: stopped"
    fi
    return
  fi
  status_one zenoh
}

launch_zenoh_client() {
  local role="$1"
  local target="$2"
  local bridge="${ROOT}/zenoh-bridge-ros2dds"
  local config
  local docker_cmd=(docker)
  local namespace_args=()
  if zenoh_uses_docker; then
    check_zenoh_docker_access
    [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
    [[ -n "${ZENOH_NAMESPACE:-}" ]] && namespace_args=(-n "${ZENOH_NAMESPACE}")
    config="$(zenoh_config_path)"
    [[ -f "${config}" ]] || { echo "Missing Zenoh config: ${config}" >&2; exit 1; }
    "${docker_cmd[@]}" rm -f "$(zenoh_docker_name "${role}")" >/dev/null 2>&1 || true
    start_bg zenoh "${docker_cmd[@]}" run --rm \
      --name "$(zenoh_docker_name "${role}")" \
      --network host \
      -e "ROS_DISTRO=${ROS_DISTRO:-jazzy}" \
      -e "ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-0}" \
      -v "${config}:/horus_zenoh.json5:ro" \
      "${ZENOH_BRIDGE_IMAGE:-eclipse/zenoh-bridge-ros2dds:${ZENOH_VERSION:-latest}}" \
      -c /horus_zenoh.json5 "${namespace_args[@]}" \
      --no-multicast-scouting -e "tcp/${target}:${ZENOH_PORT:-7447}" client
  else
    [[ -x "${bridge}" ]] || { echo "Missing Zenoh bridge. Run ./horus bootstrap ${role}." >&2; exit 1; }
    source_ros_required
    # shellcheck disable=SC2086
    start_bg zenoh "${bridge}" $(zenoh_common_args) --no-multicast-scouting -e "tcp/${target}:${ZENOH_PORT:-7447}" client
  fi
}

launch_zenoh_router() {
  local role="$1"
  local bridge="${ROOT}/zenoh-bridge-ros2dds"
  local config
  local docker_cmd=(docker)
  local namespace_args=()
  if zenoh_uses_docker; then
    check_zenoh_docker_access
    [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]] && docker_cmd=(sudo -n docker)
    [[ -n "${ZENOH_NAMESPACE:-}" ]] && namespace_args=(-n "${ZENOH_NAMESPACE}")
    config="$(zenoh_config_path)"
    [[ -f "${config}" ]] || { echo "Missing Zenoh config: ${config}" >&2; exit 1; }
    "${docker_cmd[@]}" rm -f "$(zenoh_docker_name "${role}")" >/dev/null 2>&1 || true
    start_bg zenoh "${docker_cmd[@]}" run --rm \
      --name "$(zenoh_docker_name "${role}")" \
      --network host \
      -e "ROS_DISTRO=${ROS_DISTRO:-jazzy}" \
      -e "ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-0}" \
      -v "${config}:/horus_zenoh.json5:ro" \
      "${ZENOH_BRIDGE_IMAGE:-eclipse/zenoh-bridge-ros2dds:${ZENOH_VERSION:-latest}}" \
      -c /horus_zenoh.json5 "${namespace_args[@]}" \
      -l "tcp/0.0.0.0:${ZENOH_PORT:-7447}" router
  else
    [[ -x "${bridge}" ]] || { echo "Missing Zenoh bridge. Run ./horus bootstrap ${role}." >&2; exit 1; }
    if [[ "${role}" == "cloud" ]]; then
      source_ros || true
    else
      source_ros_required
    fi
    # shellcheck disable=SC2086
    start_bg zenoh "${bridge}" $(zenoh_common_args) -l "tcp/0.0.0.0:${ZENOH_PORT:-7447}" router
  fi
}

launch_webrtc_robot() {
  local py
  local target
  ensure_webrtc_media_supported
  py="$(python_bin)"
  target="$(webrtc_signal_target)"
  source_ros_required
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    # shellcheck disable=SC2086
    start_bg webrtc "${py}" "${ROOT}/scripts/webrtc_camera_sender.py" \
      --signaling-url "ws://${target}:${WEBRTC_SIGNAL_PORT:-8765}" \
      --duration "${WEBRTC_DURATION:-86400}" \
      --camera-fps-scale "${CAMERA_FPS_SCALE:-1.0}" \
      --quality-scale "${CAMERA_QUALITY_SCALE:-1.0}" \
      --max-buffer-bytes "${WEBRTC_MAX_BUFFER_BYTES:-2000000}" \
      --ros-cmd-topic "${ROS_CMD_TOPIC:-/cmd_vel}" \
      $(ice_args) \
      --json "${RUN_DIR}/webrtc_robot_summary.json"
  else
    "${ROOT}/scripts/detect_video_stack.sh" --role robot --out "${ROOT}/.webrtc_profile.env" >/dev/null
    # shellcheck disable=SC2086
    start_bg webrtc "${py}" "${ROOT}/scripts/gst_webrtc_h264_robot.py" \
      --signaling-url "ws://${target}:${WEBRTC_SIGNAL_PORT:-8765}" \
      --room "${HORUS_ROOM:-default}" \
      --profile "${ROOT}/.webrtc_profile.env" \
      --ice-servers "${WEBRTC_ICE_SERVERS:-stun:stun.l.google.com:19302}" \
      --ros-cmd-topic "${ROS_CMD_TOPIC:-/cmd_vel}" \
      --video-source "${WEBRTC_VIDEO_SOURCE:-ros2}" \
      --ros-image-topic "${WEBRTC_ROS_IMAGE_INPUT_TOPIC:-${WEBRTC_ROS_IMAGE_TOPIC:-/camera/image_raw}}" \
      --ros-image-qos "${WEBRTC_ROS_IMAGE_QOS:-sensor_data}" \
      --source-pipeline "${WEBRTC_GST_VIDEO_SOURCE:-}" \
      --width "${WEBRTC_VIDEO_WIDTH:-1280}" \
      --height "${WEBRTC_VIDEO_HEIGHT:-720}" \
      --fps "${WEBRTC_VIDEO_FPS:-30}" \
      --duration "${WEBRTC_DURATION:-86400}"
  fi
}

launch_webrtc_receiver() {
  local role="$1"
  local py
  ensure_webrtc_media_supported
  py="$(python_bin)"
  source_ros_required
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    # shellcheck disable=SC2086
    start_bg webrtc "${py}" "${ROOT}/scripts/webrtc_camera_receiver.py" \
      --host 0.0.0.0 \
      --port "${WEBRTC_SIGNAL_PORT:-8765}" \
      --duration "${WEBRTC_DURATION:-86400}" \
      --cmd-rate "${CMD_RATE:-0}" \
      --cmd-linear-x "${CMD_LINEAR_X:-0.0}" \
      --cmd-angular-z "${CMD_ANGULAR_Z:-0.0}" \
      $(ice_args) \
      --json "${RUN_DIR}/webrtc_${role}_summary.json" \
      --csv "${RUN_DIR}/webrtc_${role}_latency.csv"
  else
    "${ROOT}/scripts/detect_video_stack.sh" --role "${role}" --out "${ROOT}/.webrtc_profile.env" >/dev/null
    if [[ "${HORUS_TOPOLOGY:-hub}" == "hub" ]]; then
      required_value HORUS_CLOUD_IP "${HORUS_CLOUD_IP:-}"
      # shellcheck disable=SC2086
      start_bg webrtc "${py}" "${ROOT}/scripts/gst_webrtc_h264_machine.py" \
        --signaling-url "ws://${HORUS_CLOUD_IP}:${WEBRTC_SIGNAL_PORT:-8765}" \
        --room "${HORUS_ROOM:-default}" \
        --profile "${ROOT}/.webrtc_profile.env" \
        --ice-servers "${WEBRTC_ICE_SERVERS:-stun:stun.l.google.com:19302}" \
        --video-sink "${WEBRTC_VIDEO_SINK:-fakesink}" \
        --video-output "${WEBRTC_VIDEO_OUTPUT:-ros2}" \
        --ros-image-topic "${WEBRTC_ROS_IMAGE_OUTPUT_TOPIC:-${WEBRTC_ROS_IMAGE_TOPIC:-/camera/webrtc/image_raw}}" \
        --ros-image-encoding "${WEBRTC_ROS_IMAGE_OUTPUT_ENCODING:-rgb8}" \
        --ros-image-frame-id "${WEBRTC_ROS_IMAGE_FRAME_ID:-webrtc_camera}" \
        --ros-image-qos "${WEBRTC_ROS_IMAGE_QOS:-sensor_data}" \
        --cmd-rate "${CMD_RATE:-0}" \
        --cmd-linear-x "${CMD_LINEAR_X:-0.0}" \
        --cmd-angular-z "${CMD_ANGULAR_Z:-0.0}" \
        --duration "${WEBRTC_DURATION:-86400}"
    else
      # shellcheck disable=SC2086
      start_bg webrtc "${py}" "${ROOT}/scripts/gst_webrtc_h264_machine.py" \
        --host 0.0.0.0 \
        --port "${WEBRTC_SIGNAL_PORT:-8765}" \
        --room "${HORUS_ROOM:-default}" \
        --profile "${ROOT}/.webrtc_profile.env" \
        --ice-servers "${WEBRTC_ICE_SERVERS:-stun:stun.l.google.com:19302}" \
        --video-sink "${WEBRTC_VIDEO_SINK:-fakesink}" \
        --video-output "${WEBRTC_VIDEO_OUTPUT:-ros2}" \
        --ros-image-topic "${WEBRTC_ROS_IMAGE_OUTPUT_TOPIC:-${WEBRTC_ROS_IMAGE_TOPIC:-/camera/webrtc/image_raw}}" \
        --ros-image-encoding "${WEBRTC_ROS_IMAGE_OUTPUT_ENCODING:-rgb8}" \
        --ros-image-frame-id "${WEBRTC_ROS_IMAGE_FRAME_ID:-webrtc_camera}" \
        --ros-image-qos "${WEBRTC_ROS_IMAGE_QOS:-sensor_data}" \
        --cmd-rate "${CMD_RATE:-0}" \
        --cmd-linear-x "${CMD_LINEAR_X:-0.0}" \
        --cmd-angular-z "${CMD_ANGULAR_Z:-0.0}" \
        --duration "${WEBRTC_DURATION:-86400}"
    fi
  fi
}

launch_signal_relay() {
  local py
  py="$(signal_python_bin)"
  start_bg signal "${py}" "${ROOT}/scripts/webrtc_signal_relay.py" \
    --host 0.0.0.0 \
    --port "${WEBRTC_SIGNAL_PORT:-8765}"
}

cmd="${1:-help}"
case "${cmd}" in
  init)
    if [[ -f "${ENV_FILE}" ]]; then
      echo "${ENV_FILE} already exists"
    else
      cp "${ROOT}/.env.example" "${ENV_FILE}"
      echo "Created ${ENV_FILE}"
    fi
    ;;
  bootstrap)
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  boostrap|bootsrap)
    echo "Interpreting '${cmd}' as 'bootstrap'."
    "${ROOT}/scripts/bootstrap.sh" "${2:-}"
    ;;
  launch)
    load_env
    role="${2:-${HORUS_ROLE:-robot}}"
    case "${role}" in
      robot|machine)
        ensure_webrtc_media_supported
        warn_runtime_config
        ;;
    esac
    case "${role}" in
      robot)
        launch_zenoh_client robot "$(zenoh_connect_target robot)"
        launch_webrtc_robot
        ;;
      machine)
        if [[ "${HORUS_TOPOLOGY:-hub}" == "direct" ]]; then
          launch_zenoh_router machine
        else
          launch_zenoh_client machine "$(zenoh_connect_target machine)"
        fi
        launch_webrtc_receiver machine
        ;;
      cloud)
        launch_zenoh_router cloud
        if [[ "${HORUS_CLOUD_RUN_SIGNALING:-1}" == "1" ]]; then
          launch_signal_relay
        fi
        ;;
      *)
        echo "Unknown launch role: ${role}" >&2
        exit 2
        ;;
    esac
    ;;
  stop)
    load_env
    stop_one webrtc
    stop_one signal
    stop_zenoh
    stop_stale_project_processes
    ;;
  status)
    load_env
    status_zenoh
    status_one signal
    status_one webrtc
    ;;
  doctor)
    load_env
    role="${2:-${HORUS_ROLE:-robot}}"
    doctor "${role}"
    ;;
  logs)
    service="${2:-}"
    case "${service}" in
      zenoh|webrtc|signal) tail -f "${RUN_DIR}/${service}.log" ;;
      *) echo "Choose a log: zenoh, webrtc, or signal" >&2; exit 2 ;;
    esac
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
