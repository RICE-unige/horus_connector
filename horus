#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUN_DIR="${HORUS_RUN_DIR:-${ROOT}/.run}"
ENV_FILE="${HORUS_ENV:-${ROOT}/.env}"
mkdir -p "${RUN_DIR}"

# ANSI color helpers
RESET="\033[0m"
BOLD="\033[1m"
FG_GREEN="\033[38;5;48m"
FG_YELLOW="\033[38;5;214m"
FG_RED="\033[38;5;203m"
FG_BLUE="\033[38;5;39m"
FG_CYAN="\033[38;5;51m"
FG_MUTED="\033[38;5;244m"

log_success() {
  echo -e "${FG_GREEN}OK${RESET}      $*"
}
log_info() {
  echo -e "${FG_BLUE}Info${RESET}    $*"
}
log_warn() {
  echo -e "${FG_YELLOW}Warning${RESET} $*"
}
log_error() {
  echo -e "${FG_RED}Error${RESET}   $*" >&2
}
log_run() {
  echo -e "${FG_CYAN}Run${RESET}     $*"
}

print_banner() {
  echo ""
  echo -e "${BOLD}${FG_CYAN}HORUS Connector${RESET}"
  echo -e "${FG_MUTED}Robot management transport layer${RESET}"
  echo ""
}

print_banner_small() {
  echo -e "${BOLD}${FG_CYAN}HORUS Connector${RESET} ${FG_MUTED}v$(cat "${ROOT}/VERSION" 2>/dev/null || echo "1.x")${RESET}"
}

usage() {
  print_banner

  echo -e "${BOLD}Usage${RESET}"
  echo -e "  ./horus ${FG_GREEN}<command>${RESET} ${FG_CYAN}[options]${RESET}\n"

  echo -e "${BOLD}Commands${RESET}"
  echo -e "  ${FG_GREEN}setup${RESET}                             Guided setup wizard"
  echo -e "  ${FG_GREEN}init${RESET}                              Create .env from the template"
  echo -e "  ${FG_GREEN}bootstrap${RESET} ${FG_CYAN}[role]${RESET}                  Install dependencies for a connector role"
  echo -e "  ${FG_GREEN}launch${RESET} ${FG_CYAN}[role] [--no-monitor]${RESET}      Start services and open the live console"
  echo -e "  ${FG_GREEN}stop${RESET}                              Stop running services"
  echo -e "  ${FG_GREEN}status${RESET} ${FG_CYAN}[--json]${RESET}                  Show service state and runtime settings"
  echo -e "  ${FG_GREEN}monitor${RESET} ${FG_CYAN}[--once]${RESET}                  Interactive live console"
  echo -e "  ${FG_GREEN}doctor${RESET} ${FG_CYAN}[role]${RESET}                    Check connectivity and listeners"
  echo -e "  ${FG_GREEN}quic${RESET} ${FG_CYAN}[setup-server|install-cert|status]${RESET} Configure Zenoh QUIC TLS"
  echo -e "  ${FG_GREEN}logs${RESET} ${FG_CYAN}[service]${RESET}                   Stream a service log"
  echo -e "  ${FG_GREEN}metrics${RESET} ${FG_CYAN}[--port 9418]${RESET}             Export Prometheus metrics and status JSON"
  echo -e "  ${FG_GREEN}fleet${RESET} ${FG_CYAN}[launch|stop|status] <file>${RESET} Start multiple rooms from one config"
  echo -e "  ${FG_GREEN}fake-data${RESET} ${FG_CYAN}[robot_id]${RESET}              Publish synthetic ROS 2 camera/state topics"
  echo ""

  echo -e "${BOLD}Roles${RESET}"
  echo -e "  ${BOLD}robot${RESET}     Robot-side system. Sends camera/state and receives velocity commands"
  echo -e "  ${BOLD}machine${RESET}   Operator/local machine. Receives camera/state and sends commands"
  echo -e "  ${BOLD}teammate${RESET}  Field teammate relay. Publishes HoloLens pose/FPV and receives guidance"
  echo -e "  ${BOLD}cloud${RESET}     Shared Zenoh router + WebRTC signaling relay, optionally TURN"
  echo ""

  echo -e "${BOLD}Topologies${RESET}"
  echo -e "  ${BOLD}hub${RESET}       Robot(s) and machine(s) connect through one cloud hub"
  echo -e "  ${BOLD}direct${RESET}    Robot connects directly to machine over VPN, Tailscale, or LAN"
  echo ""

  echo -e "${FG_MUTED}Start with ${BOLD}./horus setup${RESET}${FG_MUTED}, then run ${BOLD}./horus bootstrap <role>${RESET}${FG_MUTED} and ${BOLD}./horus launch <role>${RESET}${FG_MUTED}.${RESET}\n"
}

trim_spaces() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "${value}"
}

load_key_value_file() {
  local file="$1"
  local line key value
  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%$'\r'}"
    line="$(trim_spaces "${line}")"
    [[ -z "${line}" || "${line}" == \#* ]] && continue
    if [[ "${line}" =~ ^export[[:space:]]+(.+)$ ]]; then
      line="${BASH_REMATCH[1]}"
    fi
    if [[ ! "${line}" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      log_warn "Ignoring invalid config line in ${file}: ${line}"
      continue
    fi
    key="${BASH_REMATCH[1]}"
    value="$(trim_spaces "${BASH_REMATCH[2]}")"
    if [[ "${#value}" -ge 2 ]]; then
      if [[ "${value:0:1}" == "'" && "${value: -1}" == "'" ]]; then
        value="${value:1:${#value}-2}"
      elif [[ "${value:0:1}" == '"' && "${value: -1}" == '"' ]]; then
        value="${value:1:${#value}-2}"
      fi
    fi
    printf -v "${key}" '%s' "${value}"
    export "${key}"
  done < "${file}"
}

load_env() {
  if [[ ! -f "${ENV_FILE}" ]]; then
    echo "Missing ${ENV_FILE}. Run ./horus init first." >&2
    exit 1
  fi
  load_key_value_file "${ENV_FILE}"
  if [[ -f "${ROOT}/.zenoh_profile.env" ]]; then
    load_key_value_file "${ROOT}/.zenoh_profile.env"
  fi
  if [[ -f "${ROOT}/.zenoh_tls_profile.env" ]]; then
    load_key_value_file "${ROOT}/.zenoh_tls_profile.env"
  fi
}

source_ros() {
  local distro="${ROS_DISTRO:-jazzy}"
  if [[ -n "${ROS_SETUP_PATH:-}" ]]; then
    local setup_path="${ROS_SETUP_PATH/#\~/${HOME}}"
    if [[ -f "${setup_path}" ]]; then
      set +u
      # shellcheck source=/dev/null
      source "${setup_path}"
      set -u
      return
    fi
    echo "ROS_SETUP_PATH is set but the file does not exist: ${ROS_SETUP_PATH}" >&2
    return 1
  elif [[ -f "/opt/ros/${distro}/setup.bash" ]]; then
    set +u
    # shellcheck source=/dev/null
    source "/opt/ros/${distro}/setup.bash"
    set -u
  elif [[ -f "/opt/ros/${distro}/local_setup.bash" ]]; then
    set +u
    # shellcheck source=/dev/null
    source "/opt/ros/${distro}/local_setup.bash"
    set -u
  else
    echo "ROS setup file not found for ${distro}: /opt/ros/${distro}/setup.bash or local_setup.bash" >&2
    return 1
  fi
}

source_ros_required() {
  source_ros || exit 1
}

python_bin() {
  local py="${ROOT}/.venv-webrtc/bin/python"
  if [[ ! -x "${py}" ]]; then
    echo "python3"
    return
  fi

  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" ]]; then
    if "${py}" - <<'PY' >/dev/null 2>&1
import aiortc
import numpy
import PIL
import websockets
PY
    then
      echo "${py}"
      return
    fi
  elif "${py}" - <<'PY' >/dev/null 2>&1
try:
    import websockets
except Exception:
    import websocket
PY
  then
    echo "${py}"
    return
  fi

  echo "python3"
}

signal_python_bin() {
  local py="${ROOT}/.venv-webrtc/bin/python"
  if [[ -x "${py}" ]] && "${py}" - <<'PY' >/dev/null 2>&1
import websockets
PY
  then
    echo "${py}"
    return
  fi

  echo "python3"
}

build_ice_args() {
  local -n output_ref="$1"
  local ice="${WEBRTC_ICE_SERVERS:-stun:stun.l.google.com:19302}"
  IFS=',' read -ra servers <<< "${ice}"
  for server in "${servers[@]}"; do
    [[ -n "${server}" ]] && output_ref+=(--ice-server "${server}")
  done
}

build_webrtc_latency_probe_args() {
  local -n output_ref="$1"
  if [[ "${WEBRTC_LATENCY_PROBE:-0}" == "1" ]]; then
    output_ref+=(--latency-probe --latency-probe-rate "${WEBRTC_LATENCY_PROBE_RATE:-60.0}")
  fi
}

build_webrtc_latency_receiver_args() {
  local -n output_ref="$1"
  output_ref+=(
    --clock-offset-ms "${WEBRTC_CLOCK_OFFSET_MS:-0.0}"
    --fresh-deadline-ms "${WEBRTC_FRESH_DEADLINE_MS:-150.0}"
  )
  if [[ "${WEBRTC_LATENCY_PROBE:-0}" == "1" || -n "${WEBRTC_LATENCY_JSON:-}" ]]; then
    output_ref+=(--latency-json "${WEBRTC_LATENCY_JSON:-${RUN_DIR}/webrtc_latency.json}")
  fi
}

required_value() {
  local name="$1"
  local value="$2"
  if [[ -z "${value}" ]]; then
    echo "${name} is not set in ${ENV_FILE}" >&2
    exit 1
  fi
}

zenoh_config_path() {
  local configured="${ZENOH_CONFIG:-auto}"
  if [[ "${configured}" == "auto" || "${configured}" == "config/zenoh_split.json5" ]]; then
    case "${HORUS_ROLE:-}" in
      robot) configured="config/zenoh_robot.json5" ;;
      machine) configured="config/zenoh_machine.json5" ;;
      teammate) configured="config/zenoh_teammate.json5" ;;
      cloud) configured="config/zenoh_cloud.json5" ;;
      *) configured="config/zenoh_split.json5" ;;
    esac
  fi
  echo "${ROOT}/${configured}"
}

zenoh_runtime_config_path() {
  local base="$1"
  local out="${RUN_DIR}/zenoh_runtime_${HORUS_ROLE:-default}.json5"
  local render_args=(--base "${base}" --out "${out}")

  if zenoh_tls_file_exists "${ZENOH_TLS_ROOT_CA:-}"; then
    render_args+=(--root-ca "${ZENOH_TLS_ROOT_CA/#\~/${HOME}}")
    render_args+=(--verify-name-on-connect "${ZENOH_TLS_VERIFY_NAME:-0}")
  fi
  if zenoh_tls_file_exists "${ZENOH_TLS_LISTEN_KEY:-}" && zenoh_tls_file_exists "${ZENOH_TLS_LISTEN_CERT:-}"; then
    render_args+=(
      --listen-private-key "${ZENOH_TLS_LISTEN_KEY/#\~/${HOME}}"
      --listen-certificate "${ZENOH_TLS_LISTEN_CERT/#\~/${HOME}}"
    )
  fi

  if [[ "${#render_args[@]}" -gt 4 ]]; then
    python3 "${ROOT}/scripts/render_zenoh_config.py" "${render_args[@]}"
    echo "${out}"
  else
    echo "${base}"
  fi
}

build_zenoh_common_args() {
  local -n output_ref="$1"
  local config
  config="$(zenoh_config_path)"
  [[ -f "${config}" ]] || { echo "Missing Zenoh config: ${config}" >&2; exit 1; }
  if zenoh_quic_active; then
    config="$(zenoh_runtime_config_path "${config}")"
  fi
  output_ref+=(-c "${config}")
  if [[ -n "${ZENOH_NAMESPACE:-}" ]]; then
    output_ref+=(-n "${ZENOH_NAMESPACE}")
  fi
}

zenoh_transport() {
  local mode="${ZENOH_TRANSPORT:-auto}"
  mode="${mode,,}"
  case "${mode}" in
    auto|tcp|quic) echo "${mode}" ;;
    *)
      log_warn "Unknown ZENOH_TRANSPORT=${ZENOH_TRANSPORT}; using auto."
      echo "auto"
      ;;
  esac
}

zenoh_transport_label() {
  case "$(zenoh_transport)" in
    auto)
      if zenoh_quic_ready_any; then
        echo "auto (quic + tcp fallback)"
      elif zenoh_auto_quic_enabled; then
        echo "auto (tcp; quic TLS missing)"
      else
        echo "auto (tcp; quic not enabled)"
      fi
      ;;
    quic) echo "quic" ;;
    tcp) echo "tcp" ;;
  esac
}

zenoh_auto_quic_enabled() {
  case "${ZENOH_AUTO_ENABLE_QUIC:-0}" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

zenoh_quic_active() {
  [[ "$(zenoh_transport)" == "quic" ]] || { [[ "$(zenoh_transport)" == "auto" ]] && zenoh_auto_quic_enabled && zenoh_quic_ready_any; }
}

zenoh_tls_file_exists() {
  local value="$1"
  [[ -n "${value}" && -f "${value/#\~/${HOME}}" ]]
}

zenoh_quic_client_ready() {
  zenoh_tls_file_exists "${ZENOH_TLS_ROOT_CA:-}"
}

zenoh_quic_listener_ready() {
  zenoh_tls_file_exists "${ZENOH_TLS_LISTEN_KEY:-}" && zenoh_tls_file_exists "${ZENOH_TLS_LISTEN_CERT:-}"
}

zenoh_quic_ready_any() {
  zenoh_quic_client_ready || zenoh_quic_listener_ready
}

zenoh_quic_params() {
  local params="${ZENOH_QUIC_PARAMS:-multistream=1;mixed_rel=auto}"
  [[ -n "${params}" ]] && echo "?${params}"
}

zenoh_quic_endpoint() {
  local host="$1"
  local port="${ZENOH_PORT:-7447}"
  echo "quic/${host}:${port}$(zenoh_quic_params)"
}

zenoh_require_quic_client() {
  zenoh_quic_client_ready && return 0
  if [[ "$(zenoh_transport)" == "quic" ]]; then
    log_error "ZENOH_TRANSPORT=quic needs ZENOH_TLS_ROOT_CA."
    echo "Run './horus quic install-cert <hub-cert.pem>' on this machine, or use ZENOH_TRANSPORT=auto/tcp." >&2
    exit 2
  fi
  return 1
}

zenoh_require_quic_listener() {
  zenoh_quic_listener_ready && return 0
  if [[ "$(zenoh_transport)" == "quic" ]]; then
    log_error "ZENOH_TRANSPORT=quic needs ZENOH_TLS_LISTEN_KEY and ZENOH_TLS_LISTEN_CERT."
    echo "Run './horus quic setup-server' on the listening hub/machine, or use ZENOH_TRANSPORT=auto/tcp." >&2
    exit 2
  fi
  return 1
}

zenoh_connect_endpoints() {
  local -n output_ref="$1"
  local host="$2"
  local port="${ZENOH_PORT:-7447}"
  case "$(zenoh_transport)" in
    auto)
      if zenoh_auto_quic_enabled && zenoh_require_quic_client; then
        output_ref+=("$(zenoh_quic_endpoint "${host}")" "tcp/${host}:${port}")
      else
        output_ref+=("tcp/${host}:${port}")
      fi
      ;;
    quic)
      zenoh_require_quic_client
      output_ref+=("$(zenoh_quic_endpoint "${host}")")
      ;;
    tcp) output_ref+=("tcp/${host}:${port}") ;;
  esac
}

zenoh_listen_endpoints() {
  local -n output_ref="$1"
  local bind="${ZENOH_BIND:-0.0.0.0}"
  local port="${ZENOH_PORT:-7447}"
  case "$(zenoh_transport)" in
    auto)
      if zenoh_auto_quic_enabled && zenoh_require_quic_listener; then
        output_ref+=("$(zenoh_quic_endpoint "${bind}")" "tcp/${bind}:${port}")
      else
        output_ref+=("tcp/${bind}:${port}")
      fi
      ;;
    quic)
      zenoh_require_quic_listener
      output_ref+=("$(zenoh_quic_endpoint "${bind}")")
      ;;
    tcp) output_ref+=("tcp/${bind}:${port}") ;;
  esac
}

append_zenoh_connect_args() {
  local -n output_ref="$1"
  local target="$2"
  local endpoints=()
  local endpoint
  zenoh_connect_endpoints endpoints "${target}"
  for endpoint in "${endpoints[@]}"; do
    output_ref+=(-e "${endpoint}")
  done
}

append_zenoh_listen_args() {
  local -n output_ref="$1"
  local endpoints=()
  local endpoint
  zenoh_listen_endpoints endpoints
  for endpoint in "${endpoints[@]}"; do
    output_ref+=(-l "${endpoint}")
  done
}

join_by_comma() {
  local IFS=", "
  echo "$*"
}

zenoh_connect_summary() {
  local target="$1"
  local endpoints=()
  zenoh_connect_endpoints endpoints "${target}"
  join_by_comma "${endpoints[@]}"
}

zenoh_listen_summary() {
  local endpoints=()
  zenoh_listen_endpoints endpoints
  join_by_comma "${endpoints[@]}"
}

webrtc_control_enabled() {
  local enabled="${WEBRTC_CONTROL_ENABLED:-${WEBRTC_ENABLE_CONTROL:-0}}"
  case "${enabled,,}" in
    1|true|yes|on) echo "1" ;;
    *) echo "0" ;;
  esac
}

zenoh_docker_cmd() {
  if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
    printf '%q ' sudo -n docker
  else
    printf '%q ' docker
  fi
}

zenoh_docker_name() {
  local role="$1"
  local room="${HORUS_ROOM:-default}"
  room="${room//[^A-Za-z0-9_.-]/_}"
  echo "horus-zenoh-${role}-${room}"
}

zenoh_uses_docker() {
  [[ "${ZENOH_BRIDGE_RUNTIME:-binary}" == "docker" ]]
}

append_unique_mount_dir() {
  local -n output_ref="$1"
  local file="$2"
  local dir mount
  [[ -n "${file}" ]] || return 0
  file="${file/#\~/${HOME}}"
  [[ -e "${file}" ]] || return 0
  dir="$(dirname "${file}")"
  mount="${dir}:${dir}:ro"
  local existing
  for existing in "${output_ref[@]}"; do
    [[ "${existing}" == "${mount}" ]] && return 0
  done
  output_ref+=("${mount}")
}

zenoh_docker_tls_mount_args() {
  local -n output_ref="$1"
  local mounts=()
  local mount
  append_unique_mount_dir mounts "${ZENOH_TLS_ROOT_CA:-}"
  append_unique_mount_dir mounts "${ZENOH_TLS_LISTEN_KEY:-}"
  append_unique_mount_dir mounts "${ZENOH_TLS_LISTEN_CERT:-}"
  append_unique_mount_dir mounts "${ZENOH_TLS_CONNECT_KEY:-}"
  append_unique_mount_dir mounts "${ZENOH_TLS_CONNECT_CERT:-}"
  for mount in "${mounts[@]}"; do
    output_ref+=(-v "${mount}")
  done
}

check_zenoh_docker_access() {
  local docker_cmd=(docker)
  if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
    docker_cmd=(sudo -n docker)
  fi

  if ! "${docker_cmd[@]}" ps >/dev/null 2>&1; then
    if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" && -t 0 ]]; then
      echo "Zenoh Docker fallback needs sudo; refreshing sudo credentials."
      sudo -v
      sudo docker ps >/dev/null 2>&1 && return
    fi
    if [[ "${ZENOH_BRIDGE_DOCKER_SUDO:-0}" == "1" ]]; then
      echo "Zenoh Docker fallback needs sudo Docker access. Run 'sudo -v' before launch, or add this user to the docker group and log out/in." >&2
    else
      echo "Zenoh Docker fallback is configured, but Docker is not available to this user." >&2
    fi
    exit 1
  fi
}

zenoh_connect_target() {
  local role="$1"
  local topology="${HORUS_TOPOLOGY:-hub}"
  case "${role}:${topology}" in
    robot:hub|machine:hub|teammate:hub)
      required_value HORUS_CLOUD_IP "${HORUS_CLOUD_IP:-}"
      echo "${HORUS_CLOUD_IP}"
      ;;
    robot:direct|teammate:direct)
      required_value HORUS_MACHINE_IP "${HORUS_MACHINE_IP:-}"
      echo "${HORUS_MACHINE_IP}"
      ;;
    *)
      echo ""
      ;;
  esac
}

webrtc_signal_target() {
  if [[ -n "${HORUS_WEBRTC_SIGNAL_IP:-}" ]]; then
    echo "${HORUS_WEBRTC_SIGNAL_IP}"
  elif [[ "${HORUS_TOPOLOGY:-hub}" == "direct" ]]; then
    if [[ "${HORUS_ROLE:-}" == "machine" ]]; then
      echo "${HORUS_MACHINE_IP:-0.0.0.0}"
    else
      required_value HORUS_MACHINE_IP "${HORUS_MACHINE_IP:-}"
      echo "${HORUS_MACHINE_IP}"
    fi
  else
    required_value HORUS_CLOUD_IP "${HORUS_CLOUD_IP:-}"
    echo "${HORUS_CLOUD_IP}"
  fi
}

ensure_webrtc_media_supported() {
  if [[ "${WEBRTC_MEDIA_MODE:-h264}" == "jpeg" && "${HORUS_TOPOLOGY:-hub}" == "hub" ]]; then
    echo "WEBRTC_MEDIA_MODE=jpeg is the legacy direct-mode fallback and does not use the cloud signaling relay." >&2
    echo "Use WEBRTC_MEDIA_MODE=h264 for hub deployments, or HORUS_TOPOLOGY=direct for JPEG fallback tests." >&2
    exit 2
  fi
}

zenoh_enabled() {
  [[ "${HORUS_ZENOH_ENABLED:-1}" != "0" ]]
}

warn_runtime_config() {
  local duration="${WEBRTC_DURATION:-86400}"
  local duration_int="${duration%%.*}"
  if [[ "${duration_int}" =~ ^[0-9]+$ && "${duration_int}" -gt 0 && "${duration_int}" -lt 300 ]]; then
    echo "Warning: WEBRTC_DURATION=${duration} starts a short test session. Use 0 or 86400 for normal runs." >&2
  fi
}

tcp_probe() {
  local host="$1"
  local port="$2"
  if timeout 4 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1; then
    echo -e "${FG_GREEN}open${RESET} (${host}:${port})"
    return 0
  fi
  echo -e "${FG_RED}closed${RESET} (${host}:${port})"
  return 1
}

turn_enabled() {
  [[ "${HORUS_CLOUD_RUN_TURN:-0}" == "1" ]]
}

turn_service_name() {
  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files coturn.service >/dev/null 2>&1; then
    echo "coturn"
  elif command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files turnserver.service >/dev/null 2>&1; then
    echo "turnserver"
  else
    echo "coturn"
  fi
}

run_root_available() {
  [[ "$(id -u)" -eq 0 ]] || sudo -n true >/dev/null 2>&1
}

run_root_cmd() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
  else
    sudo -n "$@"
  fi
}

turn_running() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl --quiet is-active "$(turn_service_name)" >/dev/null 2>&1 && return 0
  fi
  pgrep -x turnserver >/dev/null 2>&1
}

start_turn_relay() {
  turn_enabled || return 0
  if ! command -v turnserver >/dev/null 2>&1; then
    log_error "TURN is enabled but coturn is not installed. Run ./horus bootstrap cloud."
    return 1
  fi
  if run_root_available; then
    bash "${ROOT}/scripts/setup_turn.sh"
    return
  fi
  if turn_running; then
    log_success "TURN relay is already running."
    return
  fi
  log_warn "TURN is enabled but cannot be started without sudo. Run ./horus bootstrap cloud on the hub."
}

stop_turn_relay() {
  turn_enabled || return 0
  if command -v systemctl >/dev/null 2>&1 && run_root_available; then
    run_root_cmd systemctl stop "$(turn_service_name)" >/dev/null 2>&1 || true
  fi
}

status_turn() {
  if ! turn_enabled; then
    printf "  %-10s %b\n" "turn" "${FG_MUTED}disabled${RESET}"
    return
  fi
  local service
  service="$(turn_service_name)"
  if turn_running; then
    printf "  %-10s %b\n" "turn" "${FG_GREEN}running${RESET} ${FG_MUTED}${service}, udp/tcp ${TURN_PORT:-3478}, relay ${TURN_MIN_PORT:-49152}-${TURN_MAX_PORT:-65535}${RESET}"
  else
    printf "  %-10s %b\n" "turn" "${FG_RED}stopped${RESET} ${FG_MUTED}${service}${RESET}"
  fi
}

doctor() {
  local role="$1"
  local target=""

  echo -e "\n${BOLD}${FG_CYAN}Connectivity doctor${RESET}"
  echo -e "  role       ${role}"
  echo -e "  topology   ${HORUS_TOPOLOGY:-hub}"
  echo -e "  room       ${HORUS_ROOM:-default}"
  warn_runtime_config
  echo ""

  case "${role}:${HORUS_TOPOLOGY:-hub}" in
    robot:direct|teammate:direct)
      target="$(zenoh_connect_target "${role}")"
      echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
      echo -e "  target     ${target}"
      echo -en "  zenoh      "
      tcp_probe "${target}" "${ZENOH_PORT:-7447}" || true
      if zenoh_quic_active; then
        echo -e "  zenoh udp  ${FG_MUTED}udp/${target}:${ZENOH_PORT:-7447} must be reachable for QUIC${RESET}"
      fi
      if [[ "${role}" != "teammate" ]]; then
        echo -en "  signaling  "
        tcp_probe "$(webrtc_signal_target)" "${WEBRTC_SIGNAL_PORT:-8765}" || true
      fi
      ;;
    machine:direct)
      echo -e "  mode       listening for direct robot connections"
      echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
      echo -e "  addresses"
      local ips
      ips=$(hostname -I 2>/dev/null || true)
      for ip in ${ips}; do
        if [[ -n "${ip}" ]]; then
          echo -e "    ${ip}"
        fi
      done
      echo -e "  expected   $(zenoh_listen_summary), tcp/0.0.0.0:${WEBRTC_SIGNAL_PORT:-8765}"
      local active_listeners
      active_listeners=$(ss -ltnp 2>/dev/null | grep -E ":(${ZENOH_PORT:-7447}|${WEBRTC_SIGNAL_PORT:-8765})" || true)
      if [[ -n "${active_listeners}" ]]; then
        echo -e "  listeners"
        while read -r line; do
          echo -e "    ${FG_GREEN}running${RESET} ${line}"
        done <<< "${active_listeners}"
      else
        echo -e "  listeners  ${FG_MUTED}none detected yet${RESET}"
      fi
      ;;
    robot:hub|machine:hub|teammate:hub)
      target="$(zenoh_connect_target "${role}")"
      echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
      echo -e "  cloud      ${target}"
      echo -en "  zenoh      "
      tcp_probe "${target}" "${ZENOH_PORT:-7447}" || true
      if zenoh_quic_active; then
        echo -e "  zenoh udp  ${FG_MUTED}udp/${target}:${ZENOH_PORT:-7447} must be reachable for QUIC${RESET}"
      fi
      if [[ "${role}" != "teammate" ]]; then
        echo -en "  signaling  "
        tcp_probe "$(webrtc_signal_target)" "${WEBRTC_SIGNAL_PORT:-8765}" || true
      fi
      if [[ "${role}" != "teammate" && ( "${WEBRTC_ICE_SERVERS:-}" == *"turn:"* || "${WEBRTC_ICE_SERVERS:-}" == *"turns:"* ) ]]; then
        echo -e "  turn       ${FG_GREEN}configured${RESET} ${FG_MUTED}${WEBRTC_ICE_SERVERS#*,}${RESET}"
      fi
      ;;
    cloud:*)
      echo -e "  mode       listening for robot and machine connections"
      echo -e "  transport  ${FG_CYAN}$(zenoh_transport_label)${RESET}"
      local active_listeners
      active_listeners=$(ss -ltunp 2>/dev/null | grep -E ":(${ZENOH_PORT:-7447}|${WEBRTC_SIGNAL_PORT:-8765}|${TURN_PORT:-3478})" || true)
      if [[ -n "${active_listeners}" ]]; then
        echo -e "  listeners"
        while read -r line; do
          echo -e "    ${FG_GREEN}running${RESET} ${line}"
        done <<< "${active_listeners}"
      else
        echo -e "  listeners  ${FG_MUTED}none detected${RESET}"
      fi
      if turn_enabled; then
        echo -e "  turn       ${FG_GREEN}enabled${RESET} udp/tcp ${TURN_PORT:-3478}, relay udp ${TURN_MIN_PORT:-49152}-${TURN_MAX_PORT:-65535}"
      fi
      ;;
  esac
  if [[ "${role}" == "teammate" ]]; then
    local hololens_host="${FIELD_TEAMMATE_HOLOLENS_HOST:-${HOLOLENS_HOST:-}}"
    echo -e "  teammate  ${FIELD_TEAMMATE_NAME:-${HORUS_ROOM:-field_teammate_1}}"
    if [[ -z "${hololens_host}" ]]; then
      echo -e "  hololens  ${FG_YELLOW}not configured${RESET} ${FG_MUTED}set FIELD_TEAMMATE_HOLOLENS_HOST${RESET}"
    else
      echo -e "  hololens  ${hololens_host}"
      echo -en "  pv        "
      tcp_probe "${hololens_host}" "${FIELD_TEAMMATE_PV_PORT:-3810}" || true
      echo -en "  pose      "
      tcp_probe "${hololens_host}" "${FIELD_TEAMMATE_SPATIAL_INPUT_PORT:-3814}" || true
      echo -en "  umq       "
      tcp_probe "${hololens_host}" "${FIELD_TEAMMATE_UMQ_PORT:-3816}" || true
    fi
  fi
  echo ""
}

start_bg() {
  local name="$1"
  shift
  local log="${RUN_DIR}/${name}.log"
  local pid="${RUN_DIR}/${name}.pid"

  if [[ -f "${pid}" ]] && kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
    log_warn "Service ${BOLD}${name}${RESET} is already running (PID $(cat "${pid}"))."
    return
  fi

  rotate_log "${name}" "${log}"
  log_run "Launching ${BOLD}${name}${RESET}... (log: ${FG_MUTED}${log}${RESET})"
  nohup "$@" >"${log}" 2>&1 < /dev/null &
  local child_pid="$!"
  echo "${child_pid}" > "${pid}"
  sleep 0.5
  if kill -0 "${child_pid}" >/dev/null 2>&1; then
    log_success "Service ${BOLD}${name}${RESET} started successfully ${FG_MUTED}(PID ${child_pid})${RESET}"
  else
    log_error "Service ${BOLD}${name}${RESET} failed to start. Check: tail -n 20 ${log}"
  fi
}

rotate_log() {
  local name="$1"
  local log="$2"
  local keep="${HORUS_LOG_KEEP:-10}"
  local archive_dir="${RUN_DIR}/logs"
  local timestamp
  [[ -s "${log}" ]] || return 0
  mkdir -p "${archive_dir}"
  timestamp="$(date '+%Y%m%d-%H%M%S')"
  mv "${log}" "${archive_dir}/${name}-${timestamp}.log"
  if [[ "${keep}" =~ ^[0-9]+$ && "${keep}" -gt 0 ]]; then
    mapfile -t old_logs < <(find "${archive_dir}" -maxdepth 1 -type f -name "${name}-*.log" | sort)
    local remove_count=$(( ${#old_logs[@]} - keep ))
    local index
    for (( index=0; index<remove_count; index++ )); do
      rm -f -- "${old_logs[$index]}"
    done
  fi
}

stop_one() {
  local name="$1"
  local pid="${RUN_DIR}/${name}.pid"
  if [[ -f "${pid}" ]]; then
    if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
      kill "$(cat "${pid}")" || true
      sleep 1
      if kill -0 "$(cat "${pid}")" >/dev/null 2>&1; then
        kill -KILL "$(cat "${pid}")" || true
      fi
      log_success "Stopped ${name}."
    fi
    rm -f "${pid}"
  fi
}

project_pid_matches() {
  local pid="$1"
  local cwd cmdline
  [[ "${pid}" == "$$" ]] && return 1
  cwd="$(readlink -f "/proc/${pid}/cwd" 2>/dev/null || true)"
  cmdline="$(tr '\0' ' ' <"/proc/${pid}/cmdline" 2>/dev/null || true)"
  [[ "${cwd}" == "${ROOT}" || "${cmdline}" == *"${ROOT}/"* ]]
}

terminate_project_pids_by_pattern() {
  local signal="$1"
  shift
  local pattern pid
  for pattern in "$@"; do
    while IFS= read -r pid; do
      if project_pid_matches "${pid}"; then
        kill "-${signal}" "${pid}" >/dev/null 2>&1 || true
      fi
    done < <(pgrep -f "${pattern}" 2>/dev/null || true)
  done
}

terminate_project_pids_by_name() {
  local signal="$1"
  shift
  local name pid
  for name in "$@"; do
    while IFS= read -r pid; do
      if project_pid_matches "${pid}"; then
        kill "-${signal}" "${pid}" >/dev/null 2>&1 || true
      fi
    done < <(pgrep -x "${name}" 2>/dev/null || true)
  done
}

