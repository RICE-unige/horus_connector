{
  plugins: {
    ros2dds: {
      // Robot profile: export local robot state to Zenoh only.
      ros_localhost_only: true,
      ros_automatic_discovery_range: "LOCALHOST",

      allow: {
        publishers: [
          "^/tf$",
          "^/.*/tf$",
          "^/tf_static$",
          "^/.*/tf_static$",
          "^/odom$",
          "^/.*/odom$",
          "^/joint_states$",
          "^/.*/joint_states$",
          "^/scan$",
          "^/.*/scan$",
          "^/points$",
          "^/.*/points$",
        ],
        subscribers: [],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },

      pub_max_frequencies: [
        ".*/tf$=20",
        ".*/tf_static$=1",
        ".*/odom$=20",
        ".*/joint_states$=20",
        ".*/scan$=10",
        ".*/points$=1",
      ],

      pub_priorities: [
        ".*/tf$=2:express",
        ".*/tf_static$=2:express",
        ".*/odom$=3:express",
        ".*/joint_states$=3",
        ".*/scan$=4",
        ".*/points$=6",
      ],

      reliable_routes_blocking: false,
      transient_local_cache_multiplier: 1,
      queries_timeout: {
        default: 1.0,
        transient_local_subscribers: 0.5,
        services: 1.0,
        actions: {
          send_goal: 1.0,
          cancel_goal: 1.0,
          get_result: 30.0,
        },
      },
    },
  },

  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false },
  },

  transport: {
    unicast: { qos: { enabled: true } },
    link: {
      tx: {
        queue: {
          batching: { enabled: false },
          congestion_control: { drop: { wait_before_drop: 0 } },
        },
      },
    },
  },
}
