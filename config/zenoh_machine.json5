{
  plugins: {
    ros2dds: {
      // Machine profile: import remote robot state from Zenoh only.
      ros_localhost_only: true,
      ros_automatic_discovery_range: "LOCALHOST",

      allow: {
        publishers: [],
        subscribers: [
          "^/tf$",
          "^/.*/tf$",
          "^/tf_static$",
          "^/.*/tf_static$",
          "^/odom$",
          "^/.*/odom$",
          "^/joint_states$",
          "^/.*/joint_states$",
          "^/scan$",
          "^/.*/scan$",
          "^/points$",
          "^/.*/points$",
        ],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },

      reliable_routes_blocking: false,
      transient_local_cache_multiplier: 1,
      queries_timeout: {
        default: 1.0,
        transient_local_subscribers: 0.5,
        services: 1.0,
        actions: {
          send_goal: 1.0,
          cancel_goal: 1.0,
          get_result: 30.0,
        },
      },
    },
  },

  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false },
  },

  transport: {
    unicast: { qos: { enabled: true } },
    link: {
      tx: {
        queue: {
          batching: { enabled: false },
          congestion_control: { drop: { wait_before_drop: 0 } },
        },
      },
    },
  },
}
