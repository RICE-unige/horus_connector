{
  plugins: {
    ros2dds: {
      // Machine profile: import remote robot state from Zenoh and export
      // operator command topics back to the selected robot.
      ros_localhost_only: true,
      ros_automatic_discovery_range: "LOCALHOST",

      allow: {
        publishers: [
          // Keep machine-side export narrow. Robot state flows toward the
          // machine, but velocity commands flow back toward the robot.
          "^/cmd_vel$",
          "^/.*/cmd_vel$",
        ],
        subscribers: [
          // Import any remote topic that this machine explicitly subscribes to.
          "^/.*$",
        ],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },

      pub_priorities: [
        ".*/cmd_vel$=1:express",
      ],

      reliable_routes_blocking: false,
      transient_local_cache_multiplier: 1,
      queries_timeout: {
        default: 1.0,
        transient_local_subscribers: 0.5,
        services: 1.0,
        actions: {
          send_goal: 1.0,
          cancel_goal: 1.0,
          get_result: 30.0,
        },
      },
    },
  },

  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false },
  },

  transport: {
    unicast: { qos: { enabled: true } },
    link: {
      tx: {
        queue: {
          batching: { enabled: false },
          congestion_control: { drop: { wait_before_drop: 0 } },
        },
      },
    },
  },
}
